    {
      name: "fullWidth",
      required: false,
      default: false,
      description: "Expands the button to fill its container width.",
      type: "boolean",
      extraction_status: "from_button_docgen"
    },
    {
      name: "disabled",
      required: false,
      description: "Disables the button.",
      type: "boolean",
      extraction_status: "from_button_docgen_tags"
    },
    {
      name: "isLoading",
      required: false,
      default: false,
      description: "Displays a loading spinner and disables interactions while an action is in progress.",
      type: "boolean",
      extraction_status: "from_button_docgen"
    },
    {
      name: "as",
      required: false,
      description: "Overrides the default HTML tag. Use anchor semantics only for navigation/link behavior.",
      type: "ElementType",
      extraction_status: "from_button_docgen"
    },
    {
      name: "href",
      required: false,
      description: "URL used when the button is rendered as an anchor.",
      type: "string",
