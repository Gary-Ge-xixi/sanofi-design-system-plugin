  const defaultText = "var(--elements-color-semantic-text-default_inverse)";
  const accentText = "var(--elements-color-semantic-text-accent-default)";
  const destructText = "var(--elements-color-semantic-text-error)";
  return {
    extraction_status: "token_guided_from_tokens_css_and_button_docgen",
    note: "Component-level Button background tokens are used where available. Other visual roles use semantic tokens; exact production CSS classes are not fully extracted in this stage.",
    variants: {
      primary: {
        background: "var(--elements-color-semantic-accent-default)",
        text: primaryText,
        border: "var(--elements-color-semantic-accent-default)",
        hover_background: "var(--elements-color-semantic-accent-hover)",
        active_background: "var(--elements-color-semantic-accent-active)"
      },
      "primary-neutral": {
        background: "var(--elements-color-semantic-accent-neutral_default)",
        text: defaultText,
        border: "var(--elements-color-semantic-border-default)",
        hover_background: "var(--elements-color-semantic-accent-neutral_hover)",
        active_background: "var(--elements-color-semantic-accent-neutral_active)"
      },
      "primary-destruct": {
        background: "var(--elements-color-semantic-destruct-default)",
        text: primaryText,
        border: "var(--elements-color-semantic-destruct-default)",
        hover_background: "var(--elements-color-semantic-destruct-hover)",
        active_background: "var(--elements-color-semantic-destruct-active)"
      },
      secondary: {
        background: "var(--elements-color-components-button-bg-secondary)",
        text: accentText,
        border: "var(--elements-color-semantic-accent-default)",
        hover_background: "var(--elements-color-semantic-background-brand-subtle)",
        active_background: "var(--elements-color-semantic-accent-neutral_active)"
      },
      "secondary-neutral": {
        background: "var(--elements-color-components-button-bg-secondary-neutral)",
