function buildButtonComponentAtomic(component, componentStories) {
  const contractPath = "design-system-plugin/design-system/contracts/components/button.contract.json";
  const primitivePath = "design-system-plugin/design-system/primitives/components/button/primitive.json";
  const expectedTabsPath = "design-system-plugin/design-system/atomic/components/button/button.expected-tabs.json";
  const docsContractPath = "design-system-plugin/design-system/atomic/components/button/docs/button.docs.contract.json";
  const packagePath = "design-system-plugin/design-system/atomic/components/button/button.package.json";
  const contract = readJsonOrNull(contractPath);
  const expectedTabs = readButtonExpectedTabs();
  const storiesById = new Map(componentStories.map((story) => [story.story_id, story]));
  const variants = BUTTON_VARIANTS.map(([id, description]) => {
    const story_id = storyIdForVariant(id);
    const materialized = storiesById.get(story_id);
    return {
      id,
      story_id,
      description,
      source: "Button docgen variant enum and Storybook story index",
      status: materialized ? "materialized" : "available_not_materialized",
      atomic_story_path: materialized?.path || "not_materialized"
    };
  });
  const expectedStoryItems = (expectedTabs.stories || []).map((expected) => {
    const materialized = storiesById.get(expected.id);
    return {
      story_id: expected.id,
      story_name: expected.name,
      export_name: expected.export_name,
      semantic_type: expected.semantic_type,
      variant: expected.variant || "not_applicable",
      expected_element: expected.element || (expected.semantic_type === "link" ? "a" : "button"),
      status: materialized ? "materialized" : "missing",
      atomic_story_path: materialized?.path || "missing",
      render_output_path: materialized?.output_path || "missing",
      source_provenance: {
        storybook_index: "research/storybook/index.json",
        docs_id: "components-button--docs",
        token_source: "foundations-colors--docs"
      }
    };
  });
  const docsContract = buildButtonDocsContract(contract, expectedTabs);
  writeJson(docsContractPath, docsContract);

  const componentAtomic = {
    schema_version: "0.2.0",
    atomic_contract_version: "0.2.0",
    component_id: component.component_id,
    component_name: component.component_name,
    renderer_target: "html",
    component_identity: {
      canonical_id: "button",
      package_import: "@sanofi-accelerator/elements/Button",
      docs_id: "components-button--docs",
      category: "Components"
    },
    stories: componentStories.map((story) => ({
      story_id: story.story_id,
      story_name: story.story_name,
      path: story.path,
      variant: story.variant,
      semantic_type: story.semantic_type || "variant",
      status: "materialized",
      template_path: story.template_path,
      output_path: story.output_path || "not_rendered"
    })),
    expected_tabs: {
      local_path: expectedTabsPath,
      docs: expectedTabs.docs || [],
      stories: expectedStoryItems
    },
    docs_contract: {
      local_path: docsContractPath,
      status: "generated"
    },
    api_arg_types: {
      extraction_status: "from_component_contract_and_story_bundle",
      props: contract?.props?.items || [],
      argTypes: [
        "variant",
        "size",
        "label",
        "icon",
        "iconPosition",
        "inverse",
        "fullWidth",
        "disabled",
        "isLoading",
        "onClick",
      "brandTheme"
      ]
    },
    variant_matrix: {
      extraction_status: "from_button_docgen_and_storybook_story_index",
      items: variants
    },
    size_matrix: {
      extraction_status: "from_button_docgen",
      exact_css_status: "official_height_extracted_padding_token_guided",
      source_note: "Button docgen exposes official heights. Padding/gap render values are token-guided until production CSS modules are fully extracted.",
      items: BUTTON_SIZES
    },
    state_matrix: {
      extraction_status: "from_storybook_overview_table_and_pseudo_parameters",
      items: BUTTON_STATES
    },
    spacing_model: {
      extraction_status: "from_storybook_layout_and_token_guided_rendering",
      story_layout: {
        stack_gap: "20px in StoryLayout source",
        table_cell_padding: "10px in ButtonsTable source"
      },
      render_tokens: {
        panel_gap: "var(--elements-spacing-lg)",
        row_gap: "var(--elements-spacing-md)",
        cell_gap: "var(--elements-spacing-sm)",
        radius: "var(--elements-radius-rounded)"
      },
      note: "Storybook layout spacing is recorded as source evidence. Rendered HTML uses Elements spacing/radius tokens."
    },
    color_token_bindings: buttonColorBindings(),
    anatomy_slots: {
      extraction_status: "from_button_component_docgen_and_render_function",
      items: [
        { id: "root", element: "button or anchor", source: "Button component render uses configurable as tag" },
        { id: "content-container", element: "span", source: "Button render function" },
        { id: "label", element: "label text", required: true, source: "Button docgen label required" },
        { id: "start-icon", prop: "icon + iconPosition=start", source: "Button docgen iconPosition enum" },
        { id: "end-icon", prop: "icon + iconPosition=end", source: "Button docgen iconPosition enum" },
        { id: "loader", prop: "isLoading", source: "Button render function and docgen" }
      ]
    },
    accessibility_rules: {
      extraction_status: "from_button_docgen_and_html_semantics",
      rules: [
        "Use button element for actions.",
        "Use anchor element only when as='a' with href is explicitly required.",
        "label is required because it provides the accessible name.",
        "disabled and isLoading both disable user interaction.",
        "focus-visible must be represented with a visible focus indicator."
      ]
    },
    render_templates: {
      html: "design-system-plugin/design-system/atomic/components/button/templates/html.button-v2.template.html",
      outputs: componentStories.map((story) => story.output_path).filter(Boolean)
    },
    validation_rules: [
      "No raw hex/rgb/hsl colors in rendered HTML.",
      "No direct core color token refs in rendered HTML.",
      "All data-primitive values must exist in primitive-index.json.",
      "All data-story-id values must exist in Button primitive known_story_ids.",
      "Every rendered sample must carry data-source-doc-id and data-token-source."
    ],
    source_provenance: {
      docs_id: "components-button--docs",
      docs_path: "design-system-plugin/design-system/knowledge/docs/components-button--docs.md",
      story_ids: (expectedTabs.stories || []).map((story) => story.id),
      materialized_story_ids: componentStories.map((story) => story.story_id),
      storybook_index: "research/storybook/index.json",
      storybook_stories: "research/storybook/stories.json",
      story_bundle: "design-system-plugin/design-system/atomic/components/button/assets/Button.stories-CGg2KCkY.js",
      component_contract: contractPath,
      primitive_contract: primitivePath,
      token_source: "foundations-colors--docs",
      token_css: "design-system-plugin/design-system/tokens/tokens.css"
    }
  };

  const packageDoc = {
    schema_version: "0.1.0",
    id: "button-complete-standard-package",
    component_id: "button",
    component_name: "Button",
    renderer_target: "html",
    coverage: {
      expected_docs: (expectedTabs.docs || []).length,
      expected_stories: (expectedTabs.stories || []).length,
      materialized_stories: expectedStoryItems.filter((story) => story.status === "materialized").length,
      docs_contract_status: "generated",
      story_coverage_status: expectedStoryItems.every((story) => story.status === "materialized") ? "complete" : "partial",
      missing_story_ids: expectedStoryItems.filter((story) => story.status !== "materialized").map((story) => story.story_id)
    },
    docs_contract: {
      docs_id: "components-button--docs",
      local_path: docsContractPath
    },
    story_atoms: expectedStoryItems,
    component_contract: contractPath,
    primitive_contract: primitivePath,
    component_atomic_contract: "design-system-plugin/design-system/atomic/components/button/component.atomic.json",
    expected_tabs: expectedTabsPath,
    token_bindings: buttonColorBindings(),
    render_outputs: {
      complete_html: "design-system-plugin/outputs/html/button-complete.atomic.html",
      per_story_outputs: expectedStoryItems.map((story) => ({
        story_id: story.story_id,
        output_path: story.render_output_path
      }))
    },
    registry: {
      package_item: "design-system-plugin/design-system/registry/items/sanofi-button-complete-package.json",
      story_item_prefix: "sanofi-button-"
    },
    validation: {
      required_story_count: 13,
      required_docs_count: 1,
      required_validators: [
        "validate-atomic-library",
        "validate-token-usage",
        "validate-primitive-usage",
        "validate-page-pattern",
        "validate-component-package-dom",
        "validate-button-package-dom",
        "validate-local-registry"
      ],
      special_semantics: [
        "Button Link must render as anchor semantics.",
        "Overview and Overview Inverse must remain matrix stories.",
        "Unknown exact CSS must stay token_guided or not_extracted."
      ]
    },
    source_provenance: {
      docs_id: "components-button--docs",
      expected_tabs: expectedTabsPath,
      docs_contract: docsContractPath,
      component_contract: contractPath,
      primitive_contract: primitivePath,
      storybook_index: "research/storybook/index.json",
      storybook_stories: "research/storybook/stories.json",
      story_bundle: "design-system-plugin/design-system/atomic/components/button/assets/Button.stories-CGg2KCkY.js",
      token_source: "foundations-colors--docs",
      token_css: "design-system-plugin/design-system/tokens/tokens.css"
    }
  };
  writeJson(packagePath, packageDoc);

  return componentAtomic;
}

fs.mkdirSync(reportDir, { recursive: true });

const storyFiles = walk(
  path.join(atomicRoot, "components"),
  (filePath) => filePath.endsWith(".story.json")
);

const stories = storyFiles.map((filePath) => {
  const story = readJson(filePath);
  return {
    story_id: story.story_id,
    story_name: story.story_name,
    component_id: story.component_id,
    component_name: story.component_name,
    variant: story.args?.values?.variant || "unknown",
    semantic_type: story.story_semantics?.semantic_type || "variant",
    expected_element: story.story_semantics?.expected_element || "button",
    path: rel(filePath),
    template_path: story.template?.local_path,
    output_path: story.template?.output_path,
    bundle_path: story.source?.local_bundle_path,
    docs_id: story.source_provenance?.docs_id,
    registry_item: `sanofi-${story.component_id}-${atomicRegistrySlug(story)}-atomic-story`
  };
});

const components = Object.values(
  stories.reduce((acc, story) => {
    if (!acc[story.component_id]) {
      acc[story.component_id] = {
        component_id: story.component_id,
        component_name: story.component_name,
        story_count: 0,
        stories: []
      };
    }
    acc[story.component_id].story_count += 1;
    acc[story.component_id].stories.push(story.story_id);
    return acc;
  }, {})
).sort((a, b) => a.component_id.localeCompare(b.component_id));

for (const component of components) {
  const componentStories = stories
    .filter((story) => story.component_id === component.component_id)
    .sort((a, b) => a.story_id.localeCompare(b.story_id));
  const componentAtomicPath = `design-system-plugin/design-system/atomic/components/${component.component_id}/component.atomic.json`;
  if (component.component_id === "button") {
    writeJson(componentAtomicPath, buildButtonComponentAtomic(component, componentStories));
  } else if (!readJsonOrNull(componentAtomicPath)) {
    writeJson(componentAtomicPath, {
      schema_version: "0.1.0",
      component_id: component.component_id,
      component_name: component.component_name,
      renderer_target: "html",
      stories: componentStories,
      source_provenance: {
        docs_id: `components-${component.component_id}--docs`
      }
    });
  }
}

const index = {
  schema_version: "0.1.0",
  generated_at: new Date().toISOString(),
  renderer_target: "html",
  source: {
    storybook_index: "research/storybook/index.json",
    storybook_stories: "research/storybook/stories.json",
    atomic_root: "design-system-plugin/design-system/atomic"
  },
  counts: {
    components: components.length,
    stories: stories.length
  },
  components,
  stories
};

writeJson("design-system-plugin/design-system/atomic/atomic-component-index.json", index);
writeJson("design-system-plugin/outputs/reports/atomic-library-build.report.json", {
  schema_version: "0.1.0",
  status: "pass",
  script: "build-atomic-library",
  output: "design-system-plugin/design-system/atomic/atomic-component-index.json",
  counts: index.counts
});

console.log(`Atomic library built: ${stories.length} stories across ${components.length} components`);
