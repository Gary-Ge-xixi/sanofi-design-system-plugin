  ["secondary", "Medium-emphasis, outlined brand-colored button for secondary actions"],
  ["secondary-neutral", "Medium-emphasis, outlined neutral button for secondary actions"],
  ["secondary-destruct", "Medium-emphasis, outlined red/danger button for destructive secondary actions"],
  ["tertiary", "Low-emphasis, text-only brand-colored button for tertiary actions"],
  ["tertiary-neutral", "Low-emphasis, text-only neutral button for tertiary actions"],
  ["tertiary-destruct", "Low-emphasis, text-only red/danger button for destructive tertiary actions"]
];

