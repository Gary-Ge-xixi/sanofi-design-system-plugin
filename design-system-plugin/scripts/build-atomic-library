  return {
    schema_version: "0.1.0",
    id: "button-docs-contract",
    component_id: "button",
    component_name: "Button",
    docs_id: "components-button--docs",
    source_url: "https://elements.prod.accelerator.sanofi/?path=/docs/components-button--docs",
    local_md_path: "design-system-plugin/design-system/knowledge/docs/components-button--docs.md",
    purpose: {
      extraction_status: "from_docs_md",
      text: "Button component is used to trigger an action or event, such as submitting a form, opening a Dialog, canceling an action, or performing a delete operation."
    },
    api_props: {
      extraction_status: "from_component_contract_and_button_docgen",
      props: propsFromDocgen,
      component_contract_props: contract?.props?.items || []
    },
    usage: {
      when_to_use: [
        "Use for actions that submit, confirm, cancel, open UI, or trigger a workflow.",
        "Use Button Link only when the element navigates like a link."
      ],
      when_not_to_use: [
        "Do not use Button Link for non-navigation actions.",
        "Do not invent variants outside the expected Button tabs."
      ],
      snippets: contract?.usage_snippets?.snippets || []
    },
    story_tabs: expectedTabs.stories || [],
    accessibility: {
      extraction_status: "from_button_docgen_and_html_semantics",
      rules: [
        "Label is required because it provides the accessible name.",
        "Use button markup for actions.",
        "Use anchor markup only for `as='a'` with `href`.",
        "Represent disabled and loading as non-interactive states.",
        "Keep visible focus indication for keyboard users."
      ]
    },
    source_provenance: {
      docs_id: "components-button--docs",
      docs_path: "design-system-plugin/design-system/knowledge/docs/components-button--docs.md",
      storybook_index: "research/storybook/index.json",
      storybook_bundle: "design-system-plugin/design-system/atomic/components/button/assets/Button.stories-CGg2KCkY.js",
      component_contract: "design-system-plugin/design-system/contracts/components/button.contract.json"
    }
  };
}

function buttonColorBindings() {
