function readButtonExpectedTabs() {
  return readJsonOrNull("design-system-plugin/design-system/atomic/components/button/button.expected-tabs.json") || {
    docs: [],
    stories: []
  };
}

function storyIdForVariant(variant) {
  if (variant === "primary-destruct") return "components-button--primary-destruct";
  if (variant === "secondary-destruct") return "components-button--secondary-destruct";
  if (variant === "tertiary-destruct") return "components-button--tertiary-destruct";
  return `components-button--${variant}`;
}

function buildButtonDocsContract(contract, expectedTabs) {
  const propsFromDocgen = [
    {
      name: "variant",
      required: false,
      default: "ButtonVariant.PRIMARY",
      description: "Visual style variant of the button.",
      values: BUTTON_VARIANTS.map(([id, description]) => ({ value: id, description })),
      extraction_status: "from_component_contract_and_button_docgen"
    },
    {
      name: "size",
      required: false,
      default: "ButtonSize.MEDIUM",
      description: "Size of the button.",
      values: BUTTON_SIZES.map((size) => ({
        value: size.id,
        official_height: size.official_height,
        usage: size.usage
      })),
      extraction_status: "from_component_contract_and_button_docgen"
    },
    {
      name: "label",
      required: true,
      description: "Text content displayed inside the button. Required for the accessible name.",
      type: "string",
      extraction_status: "from_button_docgen"
    },
    {
      name: "icon",
      required: false,
      description: "Icon to display alongside the label.",
      type: "IconName",
      extraction_status: "from_button_docgen"
    },
    {
      name: "iconPosition",
      required: false,
      default: "IconPosition.START",
      description: "Position of the icon relative to the label.",
      values: ["start", "end"],
      extraction_status: "from_button_docgen"
    },
    {
      name: "inverse",
      required: false,
      default: false,
      description: "Applies inverse styling for use on dark backgrounds.",
      type: "boolean",
      extraction_status: "from_button_docgen"
