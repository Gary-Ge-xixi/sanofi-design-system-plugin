#!/usr/bin/env node
const { renderTemplateHtml } = require("./render-template-html");

renderTemplateHtml(process.argv.slice(2));
process.exit(0);

const fs = require("fs");
const path = require("path");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");
const resolutionPath = process.argv[2]
  ? path.resolve(process.cwd(), process.argv[2])
  : path.join(pluginRoot, "design-system", "contracts", "resolvers", "latest-resolution.json");
const outputPath = process.argv[3]
  ? path.resolve(process.cwd(), process.argv[3])
  : path.join(pluginRoot, "outputs", "html", "admin-dashboard.resolved.html");
const reportDir = path.join(pluginRoot, "outputs", "reports");
const reportPath = path.join(reportDir, "html-renderer.report.json");

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function rel(filePath) {
  return path.relative(workspaceRoot, filePath);
}

function primitive(resolution, id) {
  return resolution.primitive_refs.find((item) => item.primitive_id === id) || {
    docs_id: "unknown",
    story_id: "unknown"
  };
}

function attrs(resolution, primitiveId, patternId) {
  const ref = primitive(resolution, primitiveId);
  return [
    `data-primitive="${primitiveId}"`,
    `data-story-id="${ref.story_id}"`,
    `data-source-doc-id="${ref.docs_id}"`,
    `data-pattern="${patternId}"`,
    `data-token-source="${resolution.source_provenance.token_source}"`
  ].join(" ");
}

fs.mkdirSync(path.dirname(outputPath), { recursive: true });
fs.mkdirSync(reportDir, { recursive: true });

const resolution = readJson(resolutionPath);
const nav = attrs(resolution, "navigation-header", "admin-dashboard");
const sidebar = attrs(resolution, "sidebar", "admin-dashboard");
const menu = attrs(resolution, "menu", "admin-dashboard");
const search = attrs(resolution, "search-input", "filter-toolbar");
const select = attrs(resolution, "select", "filter-toolbar");
const button = attrs(resolution, "button", "filter-toolbar");
const card = attrs(resolution, "card", "kpi-summary");
const tag = attrs(resolution, "tag", "status");
const tabs = attrs(resolution, "tabs", "work-queue");
const progress = attrs(resolution, "progress-bar", "kpi-summary");
const tableFallback = resolution.fallbacks.find((item) => item.module === "table");
const chartFallback = resolution.fallbacks.find((item) => item.module === "chart");

const html = `<!doctype html>
<html lang="zh-CN">
