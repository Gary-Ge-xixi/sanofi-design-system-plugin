      </aside>`;
}

function planningNavGroup({ label, iconName, expanded = false, active = false, children = [] }) {
  const childMarkup = children.length
    ? `<ul class="nav-sub-list" data-sidebar-part="section" ${expanded ? "" : "hidden"}>
            ${children.map((child) => `<li data-sidebar-part="item"><a class="nav-sub-item ${child.active ? "is-active" : ""}" href="${child.href || "#"}" ${child.active ? 'aria-current="page"' : ""} data-sidebar-part="item" data-primitive="menu" data-source-component="menu-menu-item" data-story-id="components-menu-menuitem--default">${child.label}</a></li>`).join("")}
          </ul>`
    : "";
  return `<li data-sidebar-part="item">
            <a class="nav-item has-toggle ${active ? "is-active" : ""}" href="#" ${active && !children.some((child) => child.active) ? 'aria-current="page"' : ""} aria-expanded="${expanded ? "true" : "false"}" data-sidebar-toggle data-sidebar-part="item" data-primitive="menu" data-source-component="menu-menu-item" data-story-id="components-menu-menuitem--default">
              <span class="nav-item-main">${icon(iconName)}<span>${label}</span></span>
              ${icon(expanded ? "chevronDown" : "chevronRight", { className: "nav-chevron", role: "sidebar-toggle" })}
            </a>
            ${childMarkup}
          </li>`;
}

