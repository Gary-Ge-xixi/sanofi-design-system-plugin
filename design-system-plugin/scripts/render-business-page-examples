function kpiCard({ id, label, value, meta, type = "quantity" }) {
  return `<article class="kpi-card" data-kpi-id="${id}" data-field-id="${id}" data-field-type="${type}" data-required="false" data-editable="false" data-field-source="business-data-model-standard">
              <span class="kpi-label">${label}</span>
              <strong class="kpi-value">${value}</strong>
              <span class="kpi-meta">${meta}</span>
            </article>`;
}

function chartRow({ label, value, width }) {
  return `<div class="chart-row" data-chart-prop="chartData">
              <span>${label}</span>
              <span class="chart-track" aria-hidden="true"><span class="chart-fill" style="inline-size: ${width};"></span></span>
              <strong>${value}</strong>
            </div>`;
}

