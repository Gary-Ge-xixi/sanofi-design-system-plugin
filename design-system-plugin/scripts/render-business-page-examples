#!/usr/bin/env node
const fs = require("fs");
const path = require("path");
const { createRuntime, runtimeStyles, runtimeScript } = require("../component-runtime/src/local-components.cjs");

const pluginRoot = path.resolve(__dirname, "..");
const htmlDir = path.join(pluginRoot, "outputs", "html");
const reportDir = path.join(pluginRoot, "outputs", "reports");
const runtime = createRuntime({
  source_provenance: {
    token_source: "foundations-colors--docs"
  },
  primitive_refs: []
});

function ensureDir(dirPath) {
  fs.mkdirSync(dirPath, { recursive: true });
}

function rel(filePath) {
  return path.relative(pluginRoot, filePath).replaceAll(path.sep, "/");
}

