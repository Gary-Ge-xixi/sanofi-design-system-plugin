      </aside>`;
}

function field({ id, label, type = "text", required = false, primitive = "text-input", value = "", control = "input", readonly = false, options = [], datePickerMode = null, datePickerSelector = null }) {
  const requiredText = required ? '<span class="required">*</span>' : "";
  const data = `data-field-id="${id}" data-field-type="${type}" data-required="${required}" data-editable="${readonly ? "false" : "true"}" data-field-source="business-data-model-standard"`;
  if (control === "date-picker") {
    const mode = datePickerMode || (type === "date-range" ? "range" : "single");
    const selectorType = datePickerSelector || "day";
    const storyId = mode === "range"
      ? "components-datepicker--range"
      : selectorType === "month"
        ? "components-datepicker--month-picker"
        : "components-datepicker--medium-size";
    return `<div class="field" ${data}>${runtime.datePicker({
      id,
      label: `${label}${required ? " *" : ""}`,
      value,
      mode,
      selectorType,
      storyId,
      instance: `date-picker.${id}`,
      pattern: "business-form-field"
    })}</div>`;
  }
  if (control === "select") {
    return `<div class="field" ${data}>${runtime.select({
      id,
      label: `${label}${required ? " *" : ""}`,
      value,
      options: options.map((option) => ({ label: option, value: option })),
      instance: `select.${id}`,
      pattern: "business-form-field"
    })}</div>`;
  }
  if (control === "textarea") {
    return `<div class="field" ${data}><label for="${id}">${label}${requiredText}</label><textarea id="${id}" data-primitive="text-area" data-source-component="text-area" data-story-id="components-textarea--default" data-source-doc-id="components-textarea--docs" data-token-source="foundations-colors--docs">${value}</textarea></div>`;
  }
  const inputType = primitive === "search-input" ? "search" : type === "date" ? "date" : "text";
  const storyId = primitive === "search-input" ? "components-searchinput--default" : `components-${primitive.replace("-", "")}--default`;
  const docsId = primitive === "search-input" ? "components-searchinput--docs" : `components-${primitive}--docs`;
  return `<div class="field" ${data}><label for="${id}">${label}${requiredText}</label><input id="${id}" type="${inputType}" value="${value}" ${readonly ? "readonly" : ""} data-primitive="${primitive}" data-source-component="${primitive}" data-story-id="${storyId}" data-source-doc-id="${docsId}" data-token-source="foundations-colors--docs"></div>`;
}

function detailValue({ id, label, type = "text", value, permission = "read" }) {
  return `<div class="field" data-field-id="${id}" data-field-type="${type}" data-required="false" data-editable="false" data-permission="${permission}" data-field-source="business-data-model-standard"><span class="field-name">${label}</span><span class="value">${value}</span></div>`;
}

