  return `<aside class="sidebar" data-primitive="sidebar" data-source-component="sidebar" data-story-id="components-sidebar--expanded" data-source-doc-id="components-sidebar--docs" data-sidebar-part="root" data-token-source="foundations-colors--docs" data-nav-default="with-icons">
        <div class="sidebar-title" data-sidebar-part="header">业务工作台</div>
        <nav aria-label="主导航" data-sidebar-part="content">
          <ul class="nav-list" data-sidebar-part="section">
            ${navItem({ label: "客户档案维护", href: "business-query-form.resolved.html", iconName: "form", active: active === "form" })}
            ${navItem({ label: "客户详情审计", href: "business-entity-detail.resolved.html", iconName: "detail", active: active === "detail" })}
            ${navItem({ label: "信息聚合", href: "information-aggregation.resolved.html", iconName: "aggregation", active: active === "aggregation" })}
            ${navItem({ label: "导入结果", iconName: "import", active: false })}
            ${navItem({ label: "权限配置", iconName: "permission", active: false })}
          </ul>
        </nav>
