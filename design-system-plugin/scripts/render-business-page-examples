ensureDir(htmlDir);
ensureDir(reportDir);

const outputs = [
  {
    id: "business-query-form",
    path: path.join(htmlDir, "business-query-form.resolved.html"),
    html: queryFormPage()
  },
  {
    id: "business-entity-detail",
    path: path.join(htmlDir, "business-entity-detail.resolved.html"),
    html: detailPage()
  },
  {
    id: "information-aggregation",
    path: path.join(htmlDir, "information-aggregation.resolved.html"),
    html: informationAggregationPage()
  },
  {
    id: "customer-detail-date-query",
    path: path.join(htmlDir, "customer-detail-date-query.resolved.html"),
    html: customerDetailDateQueryPage()
  },
  {
    id: "business-planning-target-adjustment",
    path: path.join(htmlDir, "business-planning-target-adjustment.resolved.html"),
    html: businessPlanningTargetAdjustmentPage()
  }
];

for (const output of outputs) {
  fs.writeFileSync(output.path, output.html);
}

const report = {
  schema_version: "0.1.0",
  status: "pass",
  script: "render-business-page-examples",
  generated_at: new Date().toISOString(),
  outputs: outputs.map((output) => ({
    id: output.id,
    path: rel(output.path),
    bytes: Buffer.byteLength(output.html)
  }))
};

fs.writeFileSync(path.join(reportDir, "business-page-examples-render.report.json"), JSON.stringify(report, null, 2) + "\n");
fs.writeFileSync(
  path.join(reportDir, "business-page-examples-render.report.md"),
  `# Business Page Examples Render\n\nStatus: pass\n\n${report.outputs.map((output) => `- ${output.id}: \`${output.path}\``).join("\n")}\n`
);

console.log(`Business page examples rendered: ${outputs.map((output) => rel(output.path)).join(", ")}`);
