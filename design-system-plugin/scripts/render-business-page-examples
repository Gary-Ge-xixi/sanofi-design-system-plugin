function treeToggle({ state, label, decorative = false }) {
  const expanded = state === "expanded";
  const iconName = expanded ? "remove" : "add";
  const iconPath = expanded
    ? '<path d="M7 12h10"></path>'
    : '<path d="M12 7v10"></path><path d="M7 12h10"></path>';
  const toggleIcon = iconPrimitive({
    name: iconName,
    pathData: iconPath,
    className: "tree-toggle-icon",
    role: decorative ? "section-toggle" : "tree-toggle",
    size: "0.875rem"
  });
  if (decorative) {
    return `<span class="tree-toggle" data-tree-toggle="section" data-tree-state="${state}" aria-hidden="true">${toggleIcon}</span>`;
  }
  return `<button class="tree-toggle" type="button" aria-label="${label}" aria-expanded="${expanded ? "true" : "false"}" data-tree-toggle="product" data-tree-state="${state}" data-control-size="compact" data-size-policy-override="true" data-primitive="button" data-source-component="button" data-story-id="components-button--primary" data-source-doc-id="components-button--docs" data-token-source="foundations-colors--docs">${toggleIcon}</button>`;
}

function targetTabs() {
  const tabs = [
    { id: "quarter-target", label: "季度目标" },
    { id: "month-target", label: "月度目标" },
    { id: "institution-target", label: "机构目标" },
    { id: "team-target", label: "团队目标" }
  ];
  return `<div class="planning-tabs" ${runtime.componentAttrs("tabs", "target-adjustment-tabs", "tabs.business-planning-target", {
            role: "tablist",
            "aria-label": "目标调整维度",
            "data-tabs-mode": "segmented"
          })}>
            ${tabs.map((item) => `<button class="planning-tab" type="button" role="tab" id="${item.id}-tab" aria-controls="${item.id}-panel" aria-selected="${item.id === "institution-target" ? "true" : "false"}" data-tab-target="${item.id}">${item.label}</button>`).join("")}
          </div>`;
}

