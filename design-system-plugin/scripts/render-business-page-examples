      @media (max-width: 40rem) { .main { padding: var(--elements-spacing-md); } .toolbar .field, .toolbar-actions, .form-grid .field, .detail-grid .field, .summary-grid .field, .planning-query-grid .field, .planning-query-actions { grid-column: 1 / -1; } .toolbar-actions, .planning-query-actions { justify-content: stretch; } .toolbar-actions .btn, .planning-query-actions .btn { flex: 1; } .page-header { grid-template-columns: minmax(0, 1fr); } .page-header-actions { justify-content: flex-start; } .planning-tabs { inline-size: 100%; } .planning-action-bar .btn-row { justify-content: flex-start; overflow-x: auto; } .kpi-grid { grid-template-columns: minmax(0, 1fr); } .record-toolbar, .pagination { align-items: stretch; flex-direction: column; } }
${runtimeStyles()}
`;
}

function button(label, variant = "secondary", extraAttrs = "") {
  return `<button class="btn btn-${variant}" type="button" data-primitive="button" data-source-component="button" data-story-id="components-button--primary" data-source-doc-id="components-button--docs" data-token-source="foundations-colors--docs" data-button-size="medium" ${extraAttrs}>${label}</button>`;
}

function iconPrimitive({ name, pathData, className = "nav-icon", role = "navigation", size = "1.25rem" }) {
  return `<span class="${className}" data-primitive="icon" data-source-component="icon" data-story-id="components-icon--gallery" data-source-doc-id="components-icon--docs" data-token-source="foundations-colors--docs" data-icon-name="${name}" data-icon-role="${role}" data-icon-size="${size}" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false">${pathData}</svg></span>`;
}

function icon(name, options = {}) {
  const paths = {
    form: '<path d="M6 4h12v16H6z"></path><path d="M9 8h6"></path><path d="M9 12h6"></path><path d="M9 16h3"></path>',
    detail: '<circle cx="11" cy="11" r="5"></circle><path d="m16 16 4 4"></path><path d="M9 11h4"></path>',
    aggregation: '<path d="M4 5h16"></path><path d="M4 12h16"></path><path d="M4 19h16"></path><path d="M8 8v8"></path><path d="M12 10v6"></path><path d="M16 7v9"></path>',
    import: '<path d="M12 3v10"></path><path d="m8 9 4 4 4-4"></path><path d="M5 19h14"></path>',
    permission: '<path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6z"></path><path d="m9 12 2 2 4-4"></path>',
    home: '<path d="M4 11 12 4l8 7"></path><path d="M6 10v10h12V10"></path><path d="M10 20v-6h4v6"></path>',
    territory: '<path d="M4 19 9 5l4 9 3-5 4 10"></path><path d="M4 19h16"></path>',
    target: '<rect x="5" y="5" width="14" height="14" rx="1.5"></rect><path d="M9 15V9"></path><path d="M12 15v-4"></path><path d="M15 15v-7"></path>',
    search: '<circle cx="11" cy="11" r="6"></circle><path d="m16 16 4 4"></path>',
    chevronDown: '<path d="m7 10 5 5 5-5"></path>',
    chevronRight: '<path d="m9 6 6 6-6 6"></path>',
    collapse: '<path d="M5 7h14"></path><path d="M5 12h10"></path><path d="M5 17h14"></path><path d="m9 10-2 2 2 2"></path>',
    swapHoriz: '<path d="M7 7h11"></path><path d="m15 4 3 3-3 3"></path><path d="M17 17H6"></path><path d="m9 14-3 3 3 3"></path>',
    add: '<path d="M12 7v10"></path><path d="M7 12h10"></path>',
    remove: '<path d="M7 12h10"></path>'
  };
  return iconPrimitive({
    name,
    pathData: paths[name] || paths.form,
    className: options.className || "nav-icon",
    role: options.role || "navigation",
    size: options.size || "1.25rem"
  });
}

function navItem({ label, href = "#", iconName, active }) {
  return `<li data-sidebar-part="item"><a class="nav-item ${active ? "is-active" : ""}" href="${href}" ${active ? 'aria-current="page"' : ""} data-sidebar-part="item" data-primitive="menu" data-source-component="menu-menu-item" data-story-id="components-menu-menuitem--default">${icon(iconName)}<span>${label}</span></a></li>`;
}

