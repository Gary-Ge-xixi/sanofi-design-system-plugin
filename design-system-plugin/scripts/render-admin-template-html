  const tokenSource = resolution.source_provenance.token_source;
  const layoutRule = resolution.source_provenance.layout_rule || "layout-grid-container";
  const typographyRule = "typography-font-stack";
  const docs = [
    ...new Set([
      "foundations-layout--docs",
