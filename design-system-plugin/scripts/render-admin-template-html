                <label class="field field-2"><span class="field-label">必填CDC</span><select ${selectAttrs}><option>必填CDC</option><option>全部CDC</option><option>非必填CDC</option></select></label>
                <label class="field field-2"><span class="field-label">客户分组</span><select ${selectAttrs}><option>客户分组</option><option>正式客户</option><option>目标客户</option></select></label>
                <div class="field field-4 filter-actions">
                  <button class="button primary" ${buttonAttrs} type="button">筛选</button>
                  <button class="button" ${buttonAttrs} type="button">重置</button>
                  <button class="button tertiary" ${menuAttrs} type="button" aria-haspopup="menu">更多${icon("chevronDown", "nav-icon nav-chevron")}</button>
                </div>
              </div>
            </section>

            <div class="action-bar span-full" data-pattern="table-actions" data-source-doc-id="components-button--docs">
              <button class="button primary" ${buttonAttrs} type="button">新增CDC库存</button>
              <button class="button" ${buttonAttrs} type="button">批量导入</button>
              <button class="button tertiary" ${buttonAttrs} type="button">导出</button>
            </div>

            <section class="table-surface" data-pattern="data-table-fallback" data-grid-item-span="12" data-source-doc-id="components-textinput--docs components-button--docs" data-fallback-module="table" data-fallback-reason="${tableFallback.reason}">
              <div class="table-wrap">
                <table class="data-table">
                  <thead>
                    <tr><th>年月</th><th>CDC编码</th><th>CDC名称</th><th>品规</th><th>客户分组</th><th>数量</th></tr>
                  </thead>
                  <tbody>
                    <tr class="total-row"><td colspan="5">TOTAL</td><td>600</td></tr>
                    <tr><td>2025-01</td><td>ABCD</td><td>淮北市疾病预防控制中心</td><td>70_潘太欣</td><td>正式客户</td><td><input ${textInputAttrs} type="text" value="100" aria-label="第一行数量"></td></tr>
                    <tr><td>2025-01</td><td>ABCD</td><td>淮北市疾病预防控制中心</td><td>70_潘太欣</td><td>正式客户</td><td><input ${textInputAttrs} type="text" value="100" aria-label="第二行数量"></td></tr>
                    <tr><td>2025-01</td><td>ABCD</td><td>淮北市疾病预防控制中心</td><td>70_潘太欣</td><td>正式客户</td><td><input ${textInputAttrs} type="text" value="100" aria-label="第三行数量"></td></tr>
                    <tr><td>2025-01</td><td>ABCD</td><td>淮北市疾病预防控制中心</td><td>70_潘太欣</td><td>正式客户</td><td><input ${textInputAttrs} type="text" value="100" aria-label="第四行数量"></td></tr>
                    <tr><td>2025-01</td><td>ABCD</td><td>淮北市疾病预防控制中心</td><td>70_潘太欣</td><td>正式客户</td><td><input ${textInputAttrs} type="text" value="100" aria-label="第五行数量"></td></tr>
                  </tbody>
                </table>
              </div>
              <div class="pagination">
                <span>共6条，每页</span>
                <select ${selectAttrs} aria-label="每页条数"><option>10</option><option>20</option></select>
                <span>条</span>
                <span class="page-number">1</span>
              </div>
            </section>

            <div class="save-bar span-full" data-pattern="save-footer" data-source-doc-id="components-button--docs">
              <button class="button primary" ${buttonAttrs} type="button">保存</button>
              <span class="muted">上次保存时间：2026-01-01 09:00:00</span>
            </div>
          </section>
        </div>
      </main>
    </div>
  </body>
</html>
`;

  fs.writeFileSync(outputPath, html);

  const report = {
    schema_version: "0.1.0",
    status: "pass",
    script: "render-admin-template-html",
    generated_at: new Date().toISOString(),
    input: rel(resolutionPath),
    output: rel(outputPath),
    checked: {
      renderer_target: resolution.renderer_target,
      sections: resolution.sections.length,
      required_primitives: resolution.required_primitives.length,
      layout_rule: layoutRule,
      typography_rule: typographyRule,
      template: "onecommercial-admin",
      fallback_modules: resolution.fallbacks.map((item) => item.module)
    }
  };

  fs.writeFileSync(reportPath, JSON.stringify(report, null, 2) + "\n");
  console.log(`HTML renderer OK: ${rel(outputPath)}`);
}

