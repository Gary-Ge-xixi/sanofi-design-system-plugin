#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");
const reportDir = path.join(pluginRoot, "outputs", "reports");
const target = path.resolve(process.cwd(), process.argv[2] || path.join(pluginRoot, "design-system", "page-suites", "oneorbit-approval-suite.contract.json"));
const reportPath = path.join(reportDir, "page-suite-validation.report.json");
const reportMdPath = path.join(reportDir, "page-suite-validation.report.md");

function readJson(filePath, fallback = null) {
  if (!fs.existsSync(filePath)) return fallback;
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function rel(filePath) {
  return path.relative(pluginRoot, filePath).replaceAll(path.sep, "/");
}

function existsFromWorkspace(relativePath) {
  return fs.existsSync(path.join(workspaceRoot, relativePath));
}

fs.mkdirSync(reportDir, { recursive: true });

const failures = [];
if (!fs.existsSync(target)) failures.push(`missing page-suite contract: ${target}`);
const suite = readJson(target, { routes: [], required_component_decisions: [], validators: [] });

if (suite.id !== "oneorbit-approval-suite") failures.push(`expected suite id oneorbit-approval-suite, got ${suite.id || "empty"}`);
if (suite.renderer_target !== "html") failures.push("page-suite renderer_target must be html");
if (suite.runtime_policy !== "runtime-honest-local-atomic") failures.push("page-suite runtime_policy must be runtime-honest-local-atomic");

const requiredRoutes = ["query-list", "message-todo", "report-dashboard"];
for (const routeId of requiredRoutes) {
  const route = (suite.routes || []).find((item) => item.id === routeId);
  if (!route) {
    failures.push(`missing route: ${routeId}`);
    continue;
  }
  if (!route.block) failures.push(`${routeId} missing block`);
  if (!route.output) failures.push(`${routeId} missing output`);
  if (!Array.isArray(route.required_sections) || !route.required_sections.length) {
    failures.push(`${routeId} missing required_sections`);
  }
}

for (const decision of ["table", "date-range", "message-list", "chart", "select", "search-input", "button", "tabs", "card", "icon"]) {
  if (!(suite.required_component_decisions || []).includes(decision)) {
    failures.push(`missing required component decision: ${decision}`);
  }
}

for (const fallback of ["table", "message-list", "chart"]) {
  if (!(suite.fallback_modules || []).some((item) => item.module === fallback && item.reason)) {
    failures.push(`missing fallback module with reason: ${fallback}`);
  }
}

for (const [label, filePath] of Object.entries(suite.source_provenance || {})) {
  if (typeof filePath === "string" && filePath.startsWith("design-system-plugin/") && !existsFromWorkspace(filePath)) {
    failures.push(`missing source provenance ${label}: ${filePath}`);
  }
}

for (const validator of ["validate-component-source-resolution", "validate-page-suite", "validate-data-visualization-usage", "validate-component-runtime"]) {
  if (!(suite.validators || []).includes(validator)) failures.push(`missing validator: ${validator}`);
}

const report = {
  schema_version: "0.1.0",
  script: "validate-page-suite",
  status: failures.length ? "fail" : "pass",
  target: rel(target),
  checked: {
    route_count: suite.routes?.length || 0,
    required_component_decision_count: suite.required_component_decisions?.length || 0,
    validator_count: suite.validators?.length || 0
  },
  failures
};

fs.writeFileSync(reportPath, JSON.stringify(report, null, 2) + "\n");
fs.writeFileSync(
  reportMdPath,
  `# Page Suite Validation\n\nStatus: ${report.status}\n\nTarget: \`${report.target}\`\n\n| Metric | Value |\n| --- | ---: |\n| Routes | ${report.checked.route_count} |\n| Component decisions | ${report.checked.required_component_decision_count} |\n| Validators | ${report.checked.validator_count} |\n\n## Failures\n\n${failures.length ? failures.map((failure) => `- ${failure}`).join("\n") : "- None"}\n`
);

if (failures.length) {
  console.error(`Page suite validation failed: ${failures.join("; ")}`);
  process.exit(1);
}

console.log(`Page suite OK: ${report.target}`);
