function writeSourceReports() {
  const report = {
    schema_version: "0.1.0",
    generated_at: new Date().toISOString(),
    pages: [
      {
        id: "oneorbit-has-query-list",
        output: rel(outputFiles.query),
        reference: "102086488ca7345c47b61ab0a3fd8122.png"
      },
      {
        id: "oneorbit-message-todo",
        output: rel(outputFiles.home),
        reference: "5f92f749afefbd1e28994e377bd60477.png"
      }
    ],
    component_sources: sourceEntries
  };
  fs.writeFileSync(sourceMapJsonPath, JSON.stringify(report, null, 2) + "\n");

  const rows = sourceEntries.map((entry) => [
    entry.page,
    entry.region,
    entry.component_name,
    entry.classification,
    entry.story_id || "-",
    entry.docs_id || "-",
    entry.usage,
    entry.layout_basis,
    entry.source_file
  ]);
  const md = [
    "# OneOrbit Component Source Map",
    "",
    "该报告对应两份 HTML 输出：复杂查询列表和消息待办首页。分类含义：`runtime component` 表示走本地 Sanofi runtime；`docs-backed primitive` 表示本地有组件文档和 primitive contract，但未纳入首轮 runtime；`explicit fallback module` 或 `compound fallback pattern` 表示本地缺少对应 runtime primitive，已显式声明原因。",
    "",
    fs.existsSync(sourceResolutionJsonPath)
      ? `源检索决策报告：${path.relative(pluginRoot, sourceResolutionJsonPath).replaceAll(path.sep, "/")}`
      : "源检索决策报告：尚未生成，请运行 `scripts/resolve-oneorbit-component-sources`。",
    "",
    "| Page | Region | Component | Classification | Story ID | Docs ID | Usage | Layout Basis | Source File |",
    "| --- | --- | --- | --- | --- | --- | --- | --- | --- |",
    ...rows.map((row) => `| ${row.map((value) => escapeHtml(value).replace(/\|/g, "/")).join(" | ")} |`),
    ""
  ].join("\n");
  fs.writeFileSync(sourceMapMdPath, md);
}

function main() {
  fs.mkdirSync(htmlDir, { recursive: true });
  fs.mkdirSync(reportDir, { recursive: true });
  addCoreSourceEntries();

  const queryHtml = renderQueryPage();
  const homeHtml = renderHomePage();

  fs.writeFileSync(outputFiles.query, queryHtml);
  fs.writeFileSync(outputFiles.home, homeHtml);
  writeSourceReports();

  const renderReport = {
    schema_version: "0.1.0",
    status: "pass",
    outputs: {
      query: rel(outputFiles.query),
      home: rel(outputFiles.home),
      source_map_json: rel(sourceMapJsonPath),
      source_map_markdown: rel(sourceMapMdPath)
    },
    runtime: {
      component_runtime: runtimeName,
      render_source: renderSource,
      default_size: "medium"
    },
    source_entry_count: sourceEntries.length
  };
  fs.writeFileSync(renderReportPath, JSON.stringify(renderReport, null, 2) + "\n");
  console.log(`Rendered OneOrbit reference HTML: ${rel(outputFiles.query)}, ${rel(outputFiles.home)}`);
}

main();
