    <div class="oo-span-3" ${runtime.gridItemAttrs(3, "type-filter")}>${runtime.select({
      id: "application-type",
      label: "申请类型",
      value: "请选择申请类型",
      instance: "oneorbit.query.filter.applicationType",
      options: [
        { label: "请选择申请类型", value: "请选择申请类型" },
