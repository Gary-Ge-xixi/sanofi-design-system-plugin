function messageItem(page, index) {
  sourceEntry({
    page,
    region: "Message List",
    component_name: "Card + Button + Icon",
    component_id: "message-list",
    classification: "compound fallback pattern",
    story_id: "components-card--default components-button--primary components-icon--gallery",
    docs_id: "components-card--docs components-button--docs components-icon--docs",
    usage: "消息待办列表项，包含未读点、业务字段、时间和查看详情按钮",
    layout_basis: "No MessageList primitive is registered; compose from Card/Button/Icon runtime components",
    source_file: localRuntimeSource,
    notes: runtimeResolution.fallbacks.find((item) => item.module === "message-list").reason
  });
  return runtime.card({
    className: "oo-message-card",
    pattern: "message-list-item",
    instance: `oneorbit.home.message.${index}`,
    children: `<div class="oo-message-main">
      <div class="oo-message-title"><span class="oo-status-dot" aria-hidden="true"></span><strong>HAS系统有1条新的待审批</strong></div>
