function actionLink(label) {
  return `<a class="oo-action-link" href="#" data-source-component="link" data-source-doc-id="components-link--docs" data-pattern="table-action">${escapeHtml(label)}</a>`;
}

function queryRows() {
  const groups = [
    {
      code: "ABC1234",
      hospital: "上海第一人民医院",
      rows: [
        ["达必妥 300g_AD", "3%", "医院账期过长", "Hannah2 Han;POS9877665", true],
        ["达必妥 200g_AD", "3%", "医院账期过长", "Hannah2 Han;POS9877665", false],
        ["达必妥 100g_AD", "3%", "医院账期过长", "Luha3;POS0987665", false]
      ]
    },
    {
      code: "ABC1234",
      hospital: "上海第四人民医院",
      rows: [
        ["达必妥 300g_AD", "1%", "非公立医院", "Lee3;POS4577665", false],
        ["达必妥 200g_AD", "1%", "非公立医院", "Hannah2 Han;POS9877665", false],
        ["达必妥 100g_AD", "1%", "非公立医院", "Liu2;POS9877665", false]
      ]
    },
    {
      code: "ABC1234",
      hospital: "上海第九人民医院",
      rows: [
        ["达必妥 300g_AD", "1%", "医院不足额回款", "Nan3;POS9877665", false],
        ["达必妥 100g_AD", "1%", "医院不足额回款", "Hannah2 Han;POS9877665", true]
      ]
    }
  ];

  return groups.map((group) => {
    const dataRows = group.rows.map((row) => `<tr>
      <td>${escapeHtml(row[0])}</td>
      <td>${escapeHtml(row[1])}</td>
      <td>${escapeHtml(row[2])}</td>
      <td>2024.01.01</td>
      <td>2024.03.31</td>
      <td>2024.07.01 09:12</td>
      <td>角色名称</td>
      <td>${escapeHtml(row[3])}</td>
      <td>${statusChip("HAS Query List", "审批中")}</td>
      <td class="oo-actions">${actionLink("查看")}${row[4] ? actionLink("撤销") : ""}</td>
    </tr>`).join("");
    return `<tbody class="oo-table-group" data-table-group="${escapeHtml(group.hospital)}">
      <tr class="oo-group-row">
        <th colspan="10"><span class="oo-group-code">${escapeHtml(group.code)}</span><span>${escapeHtml(group.hospital)}</span></th>
      </tr>
      ${dataRows}
    </tbody>`;
  }).join("");
}

