        { label: "非公立医院", value: "非公立医院" },
        { label: "医院不足额回款", value: "医院不足额回款" }
      ]
    })}</div>
  ${runtime.gridEnd()}`;

  return pageDocument(page, "oneorbit-query", `${oneOrbitHeader(page)}
    <main class="oo-main oo-query-main" data-oneorbit-page="query-list" data-source-report="outputs/reports/oneorbit-component-source-map.md">
      ${runtime.containerStart({ instance: "oneorbit.query.container", layoutRule: "layout-grid-container" })}
        ${breadcrumb(page)}
        <section class="oo-query-panel" ${primitiveAttrs("page-header", "oneorbit-query-page-header", "oneorbit.query.pageHeader")}>
          <div class="oo-page-heading">
            <div class="oo-title-row">
              <h1>HAS申请系统</h1>
              ${policyLink(page)}
            </div>
            <div class="oo-heading-actions">
              <span class="oo-window-date">窗口期：2024年3月26日-2024年5月31日</span>
              ${runtimeButton(page, "Page Header", "新建供货困难申请", "primary", "oneorbit.query.actions.create")}
            </div>
          </div>
          <section class="oo-filter-panel" data-pattern="admin-query-filter-panel" data-source-doc-id="components-grid--docs components-searchinput--docs components-datepicker--docs components-select--docs">
            ${filterGrid}
            <div class="oo-filter-actions">
              ${runtimeButton(page, "Filter Panel", "筛选", "secondary", "oneorbit.query.actions.filter")}
              ${runtimeButton(page, "Filter Panel", "重置", "tertiary", "oneorbit.query.actions.reset")}
            </div>
          </section>
          <section class="oo-result-section" aria-label="查询结果">
            ${runtime.tabs({
              instance: "oneorbit.query.status.tabs",
              pattern: "approval-status-tabs",
              selected: "pending",
              tabs: [
                { id: "pending", label: "审批中(8)" },
                { id: "active", label: "已生效(9)" },
                { id: "rejected", label: "已拒绝(3)" },
                { id: "expired", label: "已过期(10)" },
                { id: "all", label: "全部(66)" }
              ]
            })}
            <p class="oo-result-count">共8条</p>
            <div class="oo-table-shell" data-fallback-module="table" data-fallback-reason="${escapeHtml(runtimeResolution.fallbacks.find((item) => item.module === "table").reason)}">
              <table class="oo-data-table">
                <thead>
                  <tr>
                    <th>申请单位及产品</th>
                    <th>申请比例</th>
                    <th>申请类型</th>
                    <th>生效时间</th>
                    <th>失效时间</th>
                    <th>申请时间</th>
                    <th>审批角色</th>
                    <th>审批人</th>
                    <th>状态</th>
                    <th>操作</th>
                  </tr>
                </thead>
                ${queryRows()}
              </table>
            </div>
          </section>
        </section>
      ${runtime.containerEnd()}
    </main>`);
}

function metricCard(page, title, value, label, iconName, instance) {
  sourceEntry({
    page,
    region: "Metrics",
    component_name: "Card",
    component_id: "card",
    classification: "runtime component",
    story_id: "components-card--default",
    docs_id: "components-card--docs",
    usage: `${title}统计卡片`,
    layout_basis: "Card docs: summary surface for content and activities",
    source_file: localRuntimeSource,
    source_url: "https://elements.prod.accelerator.sanofi/?path=/docs/components-card--docs"
  });
  return runtime.card({
    className: "oo-metric-card",
    pattern: "oneorbit-metric-card",
    instance,
    children: `<div class="oo-card-title">${runtime.icon(iconName, { className: "oo-card-icon" })}<h2>${escapeHtml(title)}</h2></div>
      <div class="oo-metric-value">${escapeHtml(value)}</div>
      <p>${escapeHtml(label)}</p>`
  });
}

