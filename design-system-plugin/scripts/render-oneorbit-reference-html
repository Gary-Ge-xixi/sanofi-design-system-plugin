function searchField(page, label, placeholder, id, instance) {
  sourceEntry({
    page,
    region: "Filter Panel",
    component_name: "SearchInput",
    component_id: "search-input",
    classification: "runtime component",
    story_id: "components-searchinput--default",
    docs_id: "components-searchinput--docs",
    usage: `${label}筛选输入框，带搜索图标和 focus 状态`,
    layout_basis: "SearchInput docs: efficient text search input with integrated icon, medium size",
    source_file: localRuntimeSource,
    source_url: "https://elements.prod.accelerator.sanofi/?path=/docs/components-searchinput--docs"
  });
  return runtime.searchInput({
    id,
    label,
    placeholder,
    icon: "search",
    ariaLabel: label,
    instance
  });
}

function dateRangeField(page, label, instance) {
  const reason = runtimeResolution.fallbacks.find((item) => item.module === "date-range").reason;
  sourceEntry({
    page,
    region: "Filter Panel",
    component_name: "DatePicker",
    component_id: "date-picker",
    classification: "docs-registry-backed primitive",
    story_id: "components-datepicker--range",
    docs_id: "components-datepicker--docs",
    usage: `${label}起止日期筛选，当前为静态 range control`,
    layout_basis: "Storybook index and local registry resolve components-datepicker--range; local DateRange runtime adapter is not registered",
    source_file: "design-system-plugin/design-system/knowledge/docs/components-datepicker--docs.md",
    source_url: "https://elements.prod.accelerator.sanofi/?path=/docs/components-datepicker--docs",
    notes: reason
  });
  return `<label class="snf-field oo-date-range-field" ${primitiveAttrs("date-picker", "filter-date-range", instance, {
    "data-fallback-module": "date-range",
    "data-fallback-reason": reason,
    "data-date-picker-mode": "range",
    "data-date-picker-size": "medium",
    "data-field-control": "root",
    "data-field-control-kind": "date-range",
    "data-control-size": "medium"
  })}>
    <span class="snf-field-label">${escapeHtml(label)}</span>
    <span class="snf-control-shell oo-date-range-shell" data-control-shell="field" data-control-kind="date-range">
      <span>开始时间</span>
      <span class="oo-date-arrow" aria-hidden="true">→</span>
      <span>结束时间</span>
    </span>
  </label>`;
}

