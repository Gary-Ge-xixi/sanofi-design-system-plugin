};

const runtimeResolution = {
  schema_version: "0.1.0",
  pattern_id: "oneorbit-reference-pages",
  source_provenance: {
    token_source: tokenSource,
    layout_rule: "layout-grid-container",
    docs_ids: [
      "components-navigationheader--docs",
      "components-container--docs",
      "components-grid--docs",
      "components-button--docs",
      "components-searchinput--docs",
      "components-select--docs",
      "components-tabs--docs",
      "components-card--docs",
      "components-datepicker--docs",
      "components-chipstatus--docs",
      "components-avatar--docs",
      "foundations-layout--docs",
      "foundations-typography--docs",
      "foundations-motion--docs"
    ],
    fallback_reasons: [
      "No official Table/DataTable/DataGrid runtime component is registered locally.",
      "No local DateRange runtime adapter is registered, so range fields are docs-backed static primitives.",
      "No MessageList runtime primitive is registered locally, so messages use Card/Button/Icon runtime parts inside a compound list."
    ]
  },
  primitive_refs: [
    ...Object.keys(storyIds).map((primitive_id) => ({
      primitive_id,
      story_id: storyIds[primitive_id],
      docs_id: docsIds[primitive_id]
    })),
    ...Object.entries(extraPrimitiveRefs).map(([primitive_id, ref]) => ({
      primitive_id,
      ...ref
    }))
  ],
  fallbacks: [
    {
      module: "table",
      reason: "No official Table/DataTable/DataGrid runtime component is registered locally."
    },
    {
      module: "date-range",
      reason: "No local DateRange runtime adapter is registered, so range fields are docs-backed static primitives."
    },
    {
      module: "message-list",
      reason: "No MessageList runtime primitive is registered locally, so messages use Card/Button/Icon runtime parts inside a compound list."
    }
  ]
};

const runtime = createRuntime(runtimeResolution);

function rel(filePath) {
  return path.relative(workspaceRoot, filePath).replaceAll(path.sep, "/");
}

function escapeHtml(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function attrsFor(values) {
  return Object.entries(values)
    .filter(([, value]) => value !== undefined && value !== null && value !== false)
    .map(([key, value]) => {
      if (value === true) return key;
      return `${key}="${escapeHtml(value)}"`;
    })
    .join(" ");
}

function primitiveAttrs(primitiveId, pattern, instance, extra = {}) {
  const ref = extraPrimitiveRefs[primitiveId] || {
    story_id: storyIds[primitiveId],
    docs_id: docsIds[primitiveId]
  };
  return attrsFor({
    "data-primitive": primitiveId,
    "data-source-component": primitiveId,
    "data-story-id": ref.story_id,
    "data-source-doc-id": ref.docs_id,
    "data-pattern": pattern,
    "data-component-instance": instance,
    "data-token-source": tokenSource,
    ...extra
  });
}

function sourceEntry(entry) {
  const key = [
    entry.page,
    entry.region,
    entry.component_name,
    entry.component_id,
    entry.classification,
    entry.usage
  ].join("::");
  if (sourceEntryKeys.has(key)) return;
  sourceEntryKeys.add(key);
  sourceEntries.push({
    page: entry.page,
    region: entry.region,
    component_name: entry.component_name,
    component_id: entry.component_id,
    classification: entry.classification,
    story_id: entry.story_id,
    docs_id: entry.docs_id,
    usage: entry.usage,
    layout_basis: entry.layout_basis,
    source_file: entry.source_file,
    source_url: entry.source_url || "",
    notes: entry.notes || ""
  });
}

function addCoreSourceEntries() {
  [
    ["Both", "Global", "DESIGN.md", "design-md", "design-interface", "", "design-system/DESIGN.md", "设计系统入口、品牌资产规则、普通 medium 尺寸规则、runtime 优先规则", "基于 DESIGN.md 的生成边界和合规链路", designMdSource],
    ["Both", "Global", "tokens.css", "tokens", "design-token", "", "design-system/tokens/tokens.css", "所有颜色、间距、半径、字体、电梯阴影都从 token 变量取值", "基于 Sanofi foundation token，不在 HTML 中写 raw hex 或 px", tokenCssSource]
  ].forEach(([page, region, component_name, component_id, classification, story_id, docs_id, usage, layout_basis, source_file]) => {
    sourceEntry({
      page,
      region,
      component_name,
      component_id,
      classification,
      story_id,
      docs_id,
      usage,
      layout_basis,
      source_file
    });
  });
}

function oneOrbitHeader(page, options = {}) {
  sourceEntry({
    page,
    region: "Topbar",
    component_name: "NavigationHeader",
    component_id: "navigation-header",
    classification: "docs-backed primitive",
    story_id: "components-navigationheader--default",
    docs_id: "components-navigationheader--docs",
    usage: "页面顶栏、Sanofi logo、OneOrbit 产品名、右侧头像和通知入口",
    layout_basis: "NavigationHeader docs: sticky top application navigation with logo and actions",
    source_file: "design-system-plugin/design-system/knowledge/docs/components-navigationheader--docs.md",
    source_url: "https://elements.prod.accelerator.sanofi/?path=/docs/components-navigationheader--docs"
  });
  sourceEntry({
    page,
    region: "Topbar",
    component_name: "Brand Asset",
    component_id: "brand-logo",
    classification: "fixed asset package",
    story_id: "",
    docs_id: "brand-assets",
    usage: "左上角固定 Sanofi 官方 94x24 SVG logo 资产",
    layout_basis: "固定品牌资产包，不使用文字重绘 logo",
    source_file: "design-system-plugin/design-system/assets/brand/brand-assets.contract.json",
    source_url: "https://elements.sanofidesign.com/557b0250b/p/396515-brand-assets"
  });

  const notification = options.notification
    ? `<span class="oo-notification-badge" aria-label="未读消息">${escapeHtml(options.notification)}</span>`
    : "";

  return `<header class="oo-topbar" ${primitiveAttrs("navigation-header", "oneorbit-topbar", `${page}.topbar`)}>
    <div class="oo-brand-lockup">
      ${runtime.brandLogo({ className: "oo-brand-logo" })}
      <span class="oo-brand-divider" aria-hidden="true"></span>
      <span class="oo-product-name">OneOrbit</span>
    </div>
    <div class="oo-topbar-actions">
      ${notification}
      <span class="oo-avatar" aria-label="当前用户 L" ${primitiveAttrs("avatar", "oneorbit-user", `${page}.avatar`)}>L</span>
    </div>
  </header>`;
}

