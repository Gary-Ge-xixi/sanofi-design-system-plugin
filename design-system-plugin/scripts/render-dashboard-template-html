              </ul>
            </article>
            <section class="panel span-full" data-section="data-table-fallback" data-pattern="data-table-fallback" ${componentRuntime.gridItemAttrs("12", "priority-inventory-table")} data-source-doc-id="components-tag--docs components-button--docs" data-fallback-module="table" data-fallback-reason="${escapeHtml(tableFallbackReason)}">
              <div class="table-header"><h2>重点客户库存</h2>${componentRuntime.button({ label: "查看全部", variant: "tertiary", instance: "button.view-all" })}</div>
              <div class="table-wrap"><table><thead><tr><th>客户</th><th>区域</th><th>库存状态</th><th>风险</th><th>负责人</th></tr></thead><tbody><tr><td>淮北市疾病预防控制中心</td><td>华东</td><td>${componentRuntime.tag({ label: "低库存", variant: "branded", instance: "tag.table.low-stock" })}</td><td>补货延迟</td><td>Rita</td></tr><tr><td>广州市疾病预防控制中心</td><td>华南</td><td>${componentRuntime.tag({ label: "正常", variant: "semantic-success", instance: "tag.table.normal" })}</td><td>无</td><td>Alex</td></tr><tr><td>成都市疾病预防控制中心</td><td>西南</td><td>${componentRuntime.tag({ label: "待确认", variant: "branded", instance: "tag.table.pending" })}</td><td>批次差异</td><td>Mei</td></tr></tbody></table></div>
            </section>
            ${componentRuntime.gridEnd()}
        ${componentRuntime.containerEnd()}
      </main>
    </div>
    ${runtimeScript()}
  </body>
</html>`;

  fs.mkdirSync(path.dirname(outputPath), { recursive: true });
  fs.mkdirSync(reportDir, { recursive: true });
  fs.writeFileSync(outputPath, html);
  const responsiveBranchCount = countMatches(html, /@media|max-width|min-width/g);
  const mobileStoryRefs = countMatches(html, /components-grid--large-mobile|components-grid--mobile|components-navigationheader--mobile-view/g);
  const iconRefs = countMatches(html, /data-primitive="icon"/g);
  const iconStoryRefs = countMatches(html, /data-story-id="components-icon--gallery"/g);
  const glyphFallbacks = countMatches(html, /[□▦▤▥▣⌂✓◈]/g);
  const containerContentRefs = countMatches(html, /data-container-part="contentContainer"/g);
  const gridRootRefs = countMatches(html, /data-grid-part="root"/g);
  const gridItemRefs = countMatches(html, /data-grid-part="item"/g);
  const unconstrainedContainerRefs = countMatches(html, /\.container\s*\{[^}]*max-inline-size:\s*none/gi);
  const brandAssetRefs = countMatches(html, /data-brand-asset-id="sanofi-logo-full"/g);
  const textLogoRefs = countMatches(html, /<(?:span|div)\b[^>]*class="[^"]*\bbrand-word\b/i);
  const largeComponentSizeRefs = countMatches(html, /data-[a-z0-9-]+-size="large"/gi);
  const businessChartRegions = countMatches(html, /data-business-module="business-chart"/g);
  const chartFallbackRefs = countMatches(html, /data-pattern="chart-fallback"/g);
  const chartFallbackModuleRefs = countMatches(html, /data-fallback-module="chart"/g);
  const accessibleChartTables = countMatches(html, /data-chart-prop="accessibleDataTable"/g);
  const failures = [];
  if (deliveryContract.viewport_policy !== "desktop-only") {
    failures.push("dashboard renderer requires desktop-only delivery contract");
  }
  if (responsiveBranchCount) failures.push("dashboard renderer output contains responsive breakpoint branches");
  if (mobileStoryRefs) failures.push("dashboard renderer output contains mobile story refs");
  if (!iconRefs || !iconStoryRefs) failures.push("dashboard renderer output must include Icon primitive provenance");
  if (!brandAssetRefs) failures.push("dashboard renderer output must use fixed Sanofi brand asset");
  if (textLogoRefs) failures.push("dashboard renderer output must not recreate Sanofi logo with text markup");
  if (largeComponentSizeRefs) failures.push("dashboard renderer output must not default runtime components to large size");
  if (glyphFallbacks) failures.push("dashboard renderer output contains text glyph icon fallback");
  if (!containerContentRefs) failures.push("dashboard renderer output must include Container.contentContainer structure");
  if (!gridRootRefs || gridItemRefs < 6) failures.push("dashboard renderer output must include Grid.Root and Grid.Item structures");
  if (unconstrainedContainerRefs) failures.push("dashboard renderer output must not leave Container max-inline-size unconstrained");
  if (!businessChartRegions) failures.push("dashboard renderer output must include business-chart BarChart region");
  if (!accessibleChartTables) failures.push("dashboard renderer output must include accessible BarChart data table");
  if (chartFallbackRefs || chartFallbackModuleRefs) failures.push("dashboard renderer output must not render BarChart as chart fallback");
  fs.writeFileSync(reportPath, JSON.stringify({
    schema_version: "0.1.0",
    status: failures.length ? "fail" : "pass",
    script: "render-dashboard-template-html",
    generated_at: new Date().toISOString(),
    input: rel(resolutionPath),
    output: rel(outputPath),
    consumed: {
      registry_item: resolution.registry_item,
      pattern_id: resolution.pattern_id,
      design_md_path: resolution.source_provenance.design_md_path,
      delivery_contract: deliveryContract.id || "none",
      viewport_policy: deliveryContract.viewport_policy || "unspecified",
      layout_rule: layoutRule,
      typography_rule: typographyRule,
      required_rules: resolution.required_rules
    },
    checked: {
      renderer_target: resolution.renderer_target,
      sections: resolution.sections?.length || 0,
      required_primitives: resolution.required_primitives?.length || 0,
      responsive_branch_count: responsiveBranchCount,
      mobile_story_refs: mobileStoryRefs,
      icon_refs: iconRefs,
      icon_story_refs: iconStoryRefs,
      glyph_fallbacks: glyphFallbacks,
      brand_asset_refs: brandAssetRefs,
      text_logo_refs: textLogoRefs,
      large_component_size_refs: largeComponentSizeRefs,
      business_chart_regions: businessChartRegions,
      chart_fallback_refs: chartFallbackRefs,
      chart_fallback_module_refs: chartFallbackModuleRefs,
      accessible_chart_tables: accessibleChartTables,
      container_content_refs: containerContentRefs,
      grid_root_refs: gridRootRefs,
      grid_item_refs: gridItemRefs,
      unconstrained_container_refs: unconstrainedContainerRefs,
      fallback_modules: (resolution.fallbacks || []).map((item) => item.module)
    },
    failures
  }, null, 2) + "\n");

  if (failures.length) {
    console.error(`Dashboard HTML render failed: ${failures.join("; ")}`);
    process.exit(1);
  }

  console.log(`Dashboard HTML rendered: ${rel(outputPath)}`);
}

module.exports = { renderDashboardTemplateHtml };

if (require.main === module) {
  renderDashboardTemplateHtml(process.argv.slice(2));
}
