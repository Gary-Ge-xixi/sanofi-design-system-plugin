#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const pluginRoot = path.resolve(__dirname, "..");
const referenceFitDir = path.join(pluginRoot, "design-system", "reference-fit");
const reportDir = path.join(pluginRoot, "outputs", "reports");
const defaultHtml = path.join(pluginRoot, "outputs", "html", "admin-query-panel.resolved.html");
const reportPath = path.join(reportDir, "reference-fit.report.json");

const ruleMap = {
  "admin-data-entry-table": "admin-data-entry-table.rules.json",
  "admin-data-entry-table-reference-fit": "admin-data-entry-table.rules.json",
  "admin-dashboard-chart": "admin-dashboard-chart.rules.json",
  "admin-dashboard-chart-reference-fit": "admin-dashboard-chart.rules.json",
  "report-dashboard": "admin-dashboard-chart.rules.json",
  "business-page-family": "business-page-family.rules.json",
  "business-page-family-reference-fit": "business-page-family.rules.json",
  "oneorbit-approval-suite": "oneorbit-approval-suite.rules.json",
  "oneorbit-approval-suite-reference-fit": "oneorbit-approval-suite.rules.json",
  "oneorbit-query-list": "oneorbit-approval-suite.rules.json",
  "oneorbit-message-todo": "oneorbit-approval-suite.rules.json",
  "information-aggregation": "business-page-family.rules.json",
  "customer-detail-date-query": "business-page-family.rules.json",
  "approval-workflow": "business-page-family.rules.json",
  "entity-detail": "business-page-family.rules.json",
  "entity-form": "business-page-family.rules.json",
  "import-result": "business-page-family.rules.json",
  "permission-admin": "business-page-family.rules.json",
  "exception-state": "business-page-family.rules.json"
};

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function count(source, pattern) {
  const matches = source.match(pattern);
  return matches ? matches.length : 0;
}

function parseArgs(argv) {
  const parsed = { target: null, profile: null, rule: null };
  for (let index = 2; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === "--profile") {
      parsed.profile = argv[index + 1];
      index += 1;
    } else if (arg.startsWith("--profile=")) {
      parsed.profile = arg.slice("--profile=".length);
    } else if (arg === "--rule") {
      parsed.rule = argv[index + 1];
      index += 1;
    } else if (arg.startsWith("--rule=")) {
      parsed.rule = arg.slice("--rule=".length);
    } else if (!arg.startsWith("--") && !parsed.target) {
      parsed.target = arg;
    }
  }
  return parsed;
}

function attr(source, attribute) {
  const match = source.match(new RegExp(`${attribute}=["']([^"']+)["']`, "i"));
  return match ? match[1] : null;
}

function resolveRulePath(ruleKey) {
  if (!ruleKey) return null;
  const mapped = ruleMap[ruleKey] || ruleMap[String(ruleKey).toLowerCase()];
  if (mapped) return path.join(referenceFitDir, mapped);

  const direct = path.resolve(process.cwd(), ruleKey);
  if (fs.existsSync(direct)) return direct;

  const inReferenceFitDir = path.join(referenceFitDir, ruleKey);
  if (fs.existsSync(inReferenceFitDir)) return inReferenceFitDir;

  return null;
}

function inferRuleKey(html, explicitProfile, explicitRule) {
  if (explicitRule) return explicitRule;

  const profile = explicitProfile || attr(html, "data-page-profile");
  const referenceFit = attr(html, "data-reference-fit");
  const pageFamily = attr(html, "data-page-family");
  const oneOrbitPage = attr(html, "data-oneorbit-page");

  if (referenceFit && ruleMap[referenceFit]) return referenceFit;
  if (profile && ruleMap[profile]) return profile;
  if (pageFamily && ruleMap[pageFamily]) return pageFamily;
  if (oneOrbitPage && ["query-list", "message-todo"].includes(oneOrbitPage)) return "oneorbit-approval-suite";
  return "admin-data-entry-table";
}

function firstSectionIndex(source, sectionId) {
  const markers = [
    `data-section="${sectionId}"`,
    `data-pattern="${sectionId}"`,
    `data-template-part="${sectionId}"`,
    `data-grid-item-name="${sectionId}"`,
    `class="${sectionId}"`,
    `class='${sectionId}'`
  ];
  const indexes = markers.map((marker) => source.indexOf(marker)).filter((index) => index !== -1);
  return indexes.length ? Math.min(...indexes) : -1;
}

function sectionHtml(source, sectionId) {
  const start = firstSectionIndex(source, sectionId);
  if (start === -1) return "";
  const sectionStart = source.lastIndexOf("<", start);
  const tagNameMatch = source.slice(sectionStart, sectionStart + 60).match(/^<([a-z0-9-]+)/i);
  const tagName = tagNameMatch?.[1] || "section";
  const end = source.indexOf(`</${tagName}>`, start);
  return end === -1 ? source.slice(sectionStart) : source.slice(sectionStart, end + tagName.length + 3);
}

function checkStaticContract(html, referenceFit, failures) {
  for (const marker of referenceFit.static_fit_contract?.required_body_attributes || []) {
    if (!html.includes(marker)) failures.push(`missing reference fit body marker: ${marker}`);
  }

  for (const marker of referenceFit.static_fit_contract?.required_chart_attributes || []) {
    if (!html.includes(marker)) failures.push(`missing chart marker: ${marker}`);
  }

  for (const marker of referenceFit.static_fit_contract?.forbidden_attributes || []) {
    if (html.includes(marker)) failures.push(`forbidden reference fit attribute present: ${marker}`);
  }

  for (const fragment of referenceFit.static_fit_contract?.required_css_fragments || []) {
    if (!html.includes(fragment)) failures.push(`missing reference fit CSS fragment: ${fragment}`);
  }

  for (const fragment of referenceFit.static_fit_contract?.forbidden_css_fragments || []) {
    if (html.includes(fragment)) failures.push(`forbidden reference fit CSS fragment present: ${fragment}`);
  }
}

function validateAdminDataEntry(html, referenceFit, failures) {
  if (/label\s+class="filter-field"[^>]*>\s*<select\b/.test(html)) {
    failures.push("visible native select structure is forbidden by reference fit");
  }

  const queryToolbar = sectionHtml(html, "query-toolbar");
  const primaryActions = sectionHtml(html, "primary-actions");
  const tableSection = sectionHtml(html, "editable-data-table-fallback");

  const checked = {
    filter_fields: count(queryToolbar, /class="filter-field"/g),
    query_toolbar_buttons: count(queryToolbar, /class="btn /g),
    primary_action_buttons: count(primaryActions, /class="btn /g),
    table_columns: count(tableSection, /<th\b/g),
    table_body_rows: count(tableSection, /<tr\b/g),
    top_level_navigation_items: count(html, /data-menu-level="0"/g)
  };

  const requiredCounts = referenceFit.dom_fit_contract?.required_counts || {};
  for (const [key, expected] of Object.entries(requiredCounts)) {
    const actual = checked[key];
    if (key.startsWith("minimum_")) {
      if (actual < expected) failures.push(`${key} must be at least ${expected}, got ${actual}`);
    } else if (actual !== expected) {
      failures.push(`${key} must be ${expected}, got ${actual}`);
    }
  }

  let previousIndex = -1;
  for (const section of referenceFit.dom_fit_contract?.required_order || []) {
    const index = firstSectionIndex(html, section);
    if (index === -1) {
      failures.push(`missing ordered section: ${section}`);
      continue;
    }
    if (index < previousIndex) failures.push(`reference section order invalid around ${section}`);
    previousIndex = index;
  }

  return checked;
}

function validateDashboardChart(html, referenceFit, failures) {
  const checked = {
    required_sections: {},
    chart_regions: count(html, /data-business-module=["']business-chart["']/g),
    accessible_data_tables: count(html, /data-chart-prop=["']accessibleDataTable["']/g),
    exact_value_tables: count(html, /<table\b/g),
    fallback_tables: count(html, /data-fallback-module=["']table["']/g),
    fallback_charts: count(html, /data-fallback-module=["']chart["']/g)
  };

  for (const section of referenceFit.dom_fit_contract?.required_sections || []) {
    const exists = firstSectionIndex(html, section) !== -1;
    checked.required_sections[section] = exists;
    if (!exists) failures.push(`missing required dashboard section: ${section}`);
  }

  const chartRegion = sectionHtml(html, "chart-region");
  if (!/<h[1-6]\b/i.test(chartRegion)) failures.push("chart-region missing visible heading");
  if (!/aria-describedby|aria-label|ariaDescription/i.test(chartRegion)) {
    failures.push("chart-region missing aria description or chart summary");
  }
  if (!/data-chart-prop=["']accessibleDataTable["']|<table\b/i.test(chartRegion)) {
    failures.push("chart-region missing accessible data table or adjacent exact-value table");
  }
  if (!/empty|error|empty state|error state|状态|reserved/i.test(chartRegion)) {
    failures.push("chart-region missing empty/error state reservation");
  }
  if (checked.fallback_charts > 0) {
    failures.push("BarChart-backed report dashboard must not use chart fallback markers");
  }

  return checked;
}

function validateBusinessPageFamily(html, referenceFit, failures) {
  const checked = {
    page_family: attr(html, "data-page-family"),
    page_profile: attr(html, "data-page-profile"),
    reference_fit: attr(html, "data-reference-fit"),
    fallback_modules: count(html, /data-fallback-module=/g),
    fallback_reasons: count(html, /data-fallback-reason=/g),
    required_sections: {}
  };

  for (const marker of referenceFit.required_page_attributes || []) {
    if (!html.includes(`${marker}=`)) failures.push(`missing business page attribute: ${marker}`);
  }

  if (checked.fallback_modules !== checked.fallback_reasons) {
    failures.push("every fallback module must include data-fallback-reason");
  }

  if (checked.page_profile === "customer-detail-date-query" || checked.page_family === "customer-detail-date-query") {
    const requiredSections = [
      "query-header",
      "date-query-form",
      "customer-summary",
      "customer-detail-table",
      "result-actions",
      "pagination"
    ];
    for (const section of requiredSections) {
      const exists = firstSectionIndex(html, section) !== -1;
      checked.required_sections[section] = exists;
      if (!exists) failures.push(`missing customer detail date query section: ${section}`);
    }

    checked.date_range_controls = count(html, /data-date-picker-mode=["']range["']/g);
    checked.summary_items = count(html, /data-customer-summary-item=/g);
    checked.table_columns = count(sectionHtml(html, "customer-detail-table"), /<th\b/g);
    checked.table_rows = count(sectionHtml(html, "customer-detail-table"), /<tr\b/g);
    checked.export_actions = count(html, /data-action=["']export["']/g);
    checked.view_detail_actions = count(html, /data-action=["']view-detail["']/g);

    if (checked.date_range_controls < 1) failures.push("customer detail date query requires a date range control");
    if (checked.summary_items < 4) failures.push(`customer summary must expose at least 4 summary items, got ${checked.summary_items}`);
    if (checked.table_columns < 8) failures.push(`customer detail table must expose at least 8 columns, got ${checked.table_columns}`);
    if (checked.table_rows < 5) failures.push(`customer detail table must expose at least 5 rows, got ${checked.table_rows}`);
    if (checked.export_actions < 1 && checked.view_detail_actions < 1) {
      failures.push("customer detail date query requires export or view-detail action");
    }
  }

  return checked;
}

function regexIndex(source, pattern) {
  const match = source.match(pattern);
  return match && typeof match.index === "number" ? match.index : -1;
}

function requireSections(source, sectionMap, failures, label) {
  const checked = {};
  let previousIndex = -1;
  for (const [section, pattern] of Object.entries(sectionMap)) {
    const index = regexIndex(source, pattern);
    checked[section] = index !== -1;
    if (index === -1) {
      failures.push(`missing ${label} section: ${section}`);
      continue;
    }
    if (index < previousIndex) failures.push(`${label} section order invalid around ${section}`);
    previousIndex = index;
  }
  return checked;
}

function validateMinimumCounts(checked, requiredCounts, failures, prefix) {
  for (const [key, expected] of Object.entries(requiredCounts || {})) {
    const actual = checked[key] || 0;
    if (actual < expected) failures.push(`${prefix} ${key} must be at least ${expected}, got ${actual}`);
  }
}

function validateOneOrbitApprovalSuite(html, referenceFit, failures) {
  const page = attr(html, "data-oneorbit-page");
  const checked = {
    oneorbit_page: page,
    page_profile: attr(html, "data-page-profile"),
    native_selects: count(html, /<select\b/gi),
    large_size_attrs: count(html, /data-[a-z0-9-]+-size=["']large["']/gi),
    mobile_fragments: count(html, /@media|max-width|min-width/g),
    official_runtime_claims: count(html, /data-output-state-official-runtime=["']present["']/g),
    visible_native_select_claims: count(html, /data-select-native=["']true["']|data-native=["']true["']/g),
    sections: {}
  };

  if (checked.native_selects > 0) failures.push(`OneOrbit output must not render native select controls, got ${checked.native_selects}`);
  if (checked.large_size_attrs > 0) failures.push(`OneOrbit output must use normal/medium component size, got ${checked.large_size_attrs} large markers`);
  if (checked.mobile_fragments > 0) failures.push("OneOrbit output must not include mobile breakpoint logic");
  if (checked.official_runtime_claims > 0) failures.push("OneOrbit output must not claim official runtime");
  if (checked.visible_native_select_claims > 0) failures.push("OneOrbit Select must stay native:false");

  if (page === "query-list") {
    checked.search_input_runtime = count(html, /data-component-id=["']search-input["']/g);
    checked.date_range_runtime = count(html, /data-field-control-kind=["']date-range["']/g);
    checked.date_picker_range_adapters = count(html, /data-adapter-id=["']date-picker\.range\.local-adapter\.v1["']/g);
    checked.select_runtime = count(html, /data-component-id=["']select["']/g);
    checked.select_combobox_triggers = count(html, /role=["']combobox["'][^>]*aria-expanded=/g);
    checked.tabs_runtime = count(html, /data-component-id=["']tabs["']/g);
    checked.button_runtime = count(html, /data-component-id=["']button["']/g);
    checked.filter_grid_items = count(html, /data-grid-item-name=["'][^"']+-filter["']/g);
    checked.table_body_rows = count(html, /<tr>\s*<td>/g);
    checked.hospital_groups = count(html, /class=["'][^"']*oo-group-row/g);
    checked.table_fallback = count(html, /data-fallback-module=["']table["']/g);

    validateMinimumCounts(checked, referenceFit.dom_fit_contract?.query_list?.minimum_counts, failures, "query-list");
    if (checked.date_picker_range_adapters < 3) failures.push(`query-list DateRange must use date-picker range adapter 3 times, got ${checked.date_picker_range_adapters}`);
    if (checked.select_combobox_triggers < 1) failures.push("query-list Select must expose combobox trigger with aria-expanded");
    if (checked.table_fallback < 1) failures.push("query-list table must be explicit fallback");

    checked.sections = requireSections(html, {
      "navigation-header": /data-component-id=["']navigation-header["']/,
      breadcrumb: /data-pattern=["']oneorbit-breadcrumb["']/,
      "page-header": /data-pattern=["']oneorbit-query-page-header["']/,
      "filter-panel": /class=["'][^"']*oo-filter-panel/,
      "status-tabs": /data-component-id=["']tabs["']/,
      "table-fallback": /data-fallback-module=["']table["']/
    }, failures, "query-list");
  } else if (page === "message-todo") {
    checked.card_runtime = count(html, /data-component-id=["']card["']/g);
    checked.button_runtime = count(html, /data-component-id=["']button["']/g);
    checked.icon_runtime = count(html, /data-component-id=["']icon["']/g);
    checked.message_cards = count(html, /class=["'][^"']*oo-message-card/g);
    checked.application_cards = count(html, /class=["'][^"']*oo-app-card/g);
    checked.metric_cards = count(html, /class=["'][^"']*oo-metric-card/g);
    checked.message_list_fallback = count(html, /data-fallback-module=["']message-list["']/g);
    checked.notification_badges = count(html, /class=["'][^"']*oo-notification-badge/g);

    validateMinimumCounts(checked, referenceFit.dom_fit_contract?.message_todo?.minimum_counts, failures, "message-todo");
    if (checked.message_list_fallback < 1) failures.push("message-todo message list must be explicit compound fallback");
    if (!html.includes("你好LIO")) failures.push("message-todo missing welcome headline");

    checked.sections = requireSections(html, {
      "navigation-header": /data-component-id=["']navigation-header["']/,
      hero: /class=["'][^"']*oo-hero-text/,
      "metric-summary": /class=["'][^"']*oo-metric-row/,
      "application-list": /class=["'][^"']*oo-apps-panel/,
      "message-list-fallback": /data-fallback-module=["']message-list["']/
    }, failures, "message-todo");
  } else {
    failures.push(`unsupported OneOrbit page marker: ${page || "missing"}`);
  }

  return checked;
}

fs.mkdirSync(reportDir, { recursive: true });

const args = parseArgs(process.argv);
const target = path.resolve(process.cwd(), args.target || defaultHtml);
const failures = [];
if (!fs.existsSync(target)) failures.push(`missing HTML target: ${target}`);

const html = fs.existsSync(target) ? fs.readFileSync(target, "utf8") : "";
const inferredRuleKey = inferRuleKey(html, args.profile, args.rule);
const referenceFitPath = resolveRulePath(inferredRuleKey);
if (!referenceFitPath || !fs.existsSync(referenceFitPath)) {
  failures.push(`missing reference fit rules for: ${inferredRuleKey}`);
}

const referenceFit = referenceFitPath && fs.existsSync(referenceFitPath) ? readJson(referenceFitPath) : {};
checkStaticContract(html, referenceFit, failures);

let checked = {};
if (referenceFit.id === "admin-data-entry-table-reference-fit") {
  checked = validateAdminDataEntry(html, referenceFit, failures);
} else if (referenceFit.id === "admin-dashboard-chart-reference-fit") {
  checked = validateDashboardChart(html, referenceFit, failures);
} else if (referenceFit.id === "business-page-family-reference-fit") {
  checked = validateBusinessPageFamily(html, referenceFit, failures);
} else if (referenceFit.id === "oneorbit-approval-suite-reference-fit") {
  checked = validateOneOrbitApprovalSuite(html, referenceFit, failures);
}

const report = {
  schema_version: "0.1.0",
  status: failures.length ? "fail" : "pass",
  script: "validate-reference-fit",
  target: path.relative(pluginRoot, target),
  selected_rule_key: inferredRuleKey,
  reference_fit: referenceFit.id || "unknown",
  reference_fit_path: referenceFitPath ? path.relative(pluginRoot, referenceFitPath) : null,
  page_profile: attr(html, "data-page-profile"),
  page_family: attr(html, "data-page-family"),
  checked,
  screenshot_gate: referenceFit.screenshot_gate || {},
  failures
};

fs.writeFileSync(reportPath, JSON.stringify(report, null, 2) + "\n");
if (failures.length) {
  console.error(`Reference fit validation failed: ${failures.join("; ")}`);
  process.exit(1);
}

console.log(`Reference fit OK: ${path.relative(pluginRoot, target)} (${referenceFit.id})`);
