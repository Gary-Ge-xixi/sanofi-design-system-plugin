#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");
const reportDir = path.join(pluginRoot, "outputs", "reports");
const resolutionPath = path.join(pluginRoot, "design-system", "contracts", "resolvers", "latest-resolution.json");
const schemaPath = path.join(pluginRoot, "design-system", "contracts", "schemas", "pattern-resolver.schema.json");
const reportPath = path.join(reportDir, "pattern-resolver-validation.report.json");

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function absFromWorkspace(relativePath) {
  return path.join(workspaceRoot, relativePath);
}

function validatePatternResolver() {
  fs.mkdirSync(reportDir, { recursive: true });
  const failures = [];
  if (!fs.existsSync(resolutionPath)) failures.push("missing latest-resolution.json");

  const resolution = fs.existsSync(resolutionPath) ? readJson(resolutionPath) : {};
  const schema = readJson(schemaPath);

  for (const field of schema.required_fields || []) {
    if (!(field in resolution)) failures.push(`resolution missing ${field}`);
  }

  const patternPath = resolution.execution_inputs?.pattern
    ? absFromWorkspace(resolution.execution_inputs.pattern)
    : null;
  const pattern = patternPath && fs.existsSync(patternPath) ? readJson(patternPath) : null;
  if (!pattern) failures.push("resolution execution_inputs.pattern does not point to a readable pattern file");

  const sectionIds = new Set((resolution.sections || []).map((section) => section.id));
  const requiredSections = pattern?.required_sections || schema.required_admin_sections || [];
  const missingSections = requiredSections.filter((id) => !sectionIds.has(id));
  if (missingSections.length) failures.push(`missing pattern sections: ${missingSections.join(", ")}`);

  const forbiddenSections = pattern?.forbidden_sections || resolution.forbidden_sections || [];
  const presentForbiddenSections = forbiddenSections.filter((id) => sectionIds.has(id));
  if (presentForbiddenSections.length) {
    failures.push(`forbidden sections present: ${presentForbiddenSections.join(", ")}`);
  }

  for (const primitive of pattern?.required_primitives || []) {
    if (!(resolution.required_primitives || []).includes(primitive)) {
      failures.push(`missing required primitive: ${primitive}`);
    }
  }

  const requiredRules = (pattern?.required_rules || []).map((rule) => typeof rule === "string" ? rule : rule.id);
  for (const rule of requiredRules) {
    if (!(resolution.required_rules || []).includes(rule)) failures.push(`missing required rule: ${rule}`);
  }

  for (const fallback of pattern?.fallbacks || []) {
    if (!(resolution.fallbacks || []).some((item) => item.module === fallback.module)) {
      failures.push(`missing fallback: ${fallback.module}`);
    }
  }

  if (pattern?.id === "admin-dashboard") {
    if (!(pattern.required_primitives || []).includes("icon")) {
      failures.push("admin-dashboard pattern must require icon primitive");
    }
    if (!(resolution.required_primitives || []).includes("icon")) {
      failures.push("admin-dashboard resolution must include icon primitive");
    }
    if (!requiredRules.includes("admin-delivery-contract")) {
      failures.push("admin-dashboard pattern must require admin-delivery-contract rule");
    }
    if (!pattern.delivery_contract || pattern.delivery_contract.viewport_policy !== "desktop-only") {
      failures.push("admin-dashboard pattern must declare desktop-only delivery contract");
    }
    if (!resolution.delivery_contract || resolution.delivery_contract.viewport_policy !== "desktop-only") {
      failures.push("admin-dashboard resolution must carry desktop-only delivery contract");
    }
  }

  if (resolution.renderer_target !== "html") failures.push("renderer target must be html");
  if (!resolution.registry_item) failures.push("missing registry_item");
  if (!resolution.template_id) failures.push("missing template_id");
  if (!resolution.source_provenance?.docs_ids?.length) failures.push("missing docs provenance");
  if (!resolution.source_provenance?.story_ids?.length) failures.push("missing story provenance");
  if (!resolution.source_provenance?.fallback_reasons?.length) failures.push("missing fallback provenance");
  if (resolution.source_provenance?.layout_rule !== "layout-grid-container") {
    failures.push("missing layout-grid-container resolver provenance");
  }
  if (!resolution.execution_inputs?.registry_item) failures.push("missing registry item execution input");
  if (!resolution.execution_inputs?.template) failures.push("missing template execution input");
  if (!resolution.execution_inputs?.semantic_token_map) failures.push("missing semantic token map execution input");

  if (resolution.pattern_id === "admin-query-panel" || /CDC|库存|填报|OneCommercial/i.test(resolution.prompt || "")) {
    if (resolution.registry_item !== "sanofi-admin-query-panel") {
      failures.push("query/fill prompt must resolve to sanofi-admin-query-panel");
    }
    if (resolution.template_id !== "onecommercial-admin-query-panel") {
      failures.push("query/fill prompt must resolve to onecommercial-admin-query-panel template");
    }
    if (resolution.page_subtype !== "data-entry-table-page") {
      failures.push("query/fill prompt must resolve page_subtype data-entry-table-page");
    }
    if (!(resolution.required_primitives || []).includes("icon")) {
      failures.push("query/fill prompt must include icon primitive for sidebar/navigation icons");
    }
    for (const genericPrimitive of ["card", "tabs", "progress-bar"]) {
      if ((resolution.required_primitives || []).includes(genericPrimitive)) {
        failures.push(`query/fill prompt must not require generic dashboard primitive: ${genericPrimitive}`);
      }
    }
    for (const genericSection of ["kpi-summary", "work-queue", "chart-fallback", "chart-region"]) {
      if (sectionIds.has(genericSection)) {
        failures.push(`query/fill prompt must not include generic dashboard section: ${genericSection}`);
      }
    }
  }

  const isReportDashboard = (
    resolution.pattern_id === "report-dashboard" ||
    resolution.registry_item === "sanofi-report-dashboard" ||
    resolution.template_id === "report-dashboard" ||
    resolution.page_profile?.id === "report-dashboard"
  );
  if (isReportDashboard) {
    if (resolution.template_id !== "report-dashboard") {
      failures.push("report dashboard prompt must resolve to report-dashboard template");
    }
    if (resolution.page_subtype !== "report-dashboard-page") {
      failures.push("report dashboard prompt must resolve page_subtype report-dashboard-page");
    }
    if (resolution.page_profile?.id !== "report-dashboard") {
      failures.push("report dashboard prompt must carry report-dashboard page profile");
    }
    if (!sectionIds.has("chart-region")) {
      failures.push("report dashboard must include chart-region section");
    }
    if (sectionIds.has("chart-fallback")) {
      failures.push("report dashboard must not include chart-fallback section for BarChart");
    }
    if (!sectionIds.has("data-table-fallback")) {
      failures.push("report dashboard must keep table fallback explicit");
    }
    if (!(resolution.execution_inputs?.module_contracts || []).some((item) => /business-chart\.contract\.json$/.test(item))) {
      failures.push("report dashboard must load business-chart module contract");
    }
    if (!/admin-dashboard-chart\.rules\.json$/.test(resolution.execution_inputs?.reference_fit_rule || "")) {
      failures.push("report dashboard must use admin-dashboard-chart reference-fit rule");
    }
  }

  const isCustomerDetailDateQuery = (
    resolution.pattern_id === "customer-detail-date-query" ||
    resolution.registry_item === "sanofi-customer-detail-date-query" ||
    resolution.template_id === "customer-detail-date-query" ||
    resolution.page_profile?.id === "customer-detail-date-query"
  );
  if (isCustomerDetailDateQuery) {
    if (resolution.registry_item !== "sanofi-customer-detail-date-query") {
      failures.push("customer detail date query prompt must resolve to sanofi-customer-detail-date-query");
    }
    if (resolution.template_id !== "customer-detail-date-query") {
      failures.push("customer detail date query prompt must resolve to customer-detail-date-query template");
    }
    if (resolution.page_subtype !== "customer-detail-date-query-page") {
      failures.push("customer detail date query prompt must resolve page_subtype customer-detail-date-query-page");
    }
    if (resolution.page_profile?.id !== "customer-detail-date-query") {
      failures.push("customer detail date query prompt must carry customer-detail-date-query page profile");
    }
    for (const section of ["date-query-form", "customer-summary", "customer-detail-table", "result-actions", "pagination"]) {
      if (!sectionIds.has(section)) failures.push(`customer detail date query must include section: ${section}`);
    }
    if (!(resolution.required_primitives || []).includes("date-picker")) {
      failures.push("customer detail date query must include DatePicker primitive");
    }
    if (!(resolution.execution_inputs?.module_contracts || []).some((item) => /business-form\.contract\.json$/.test(item))) {
      failures.push("customer detail date query must load business-form module contract");
    }
    if (!(resolution.execution_inputs?.module_contracts || []).some((item) => /business-table\.contract\.json$/.test(item))) {
      failures.push("customer detail date query must load business-table module contract");
    }
    if (!/business-page-family\.rules\.json$/.test(resolution.execution_inputs?.reference_fit_rule || "")) {
      failures.push("customer detail date query must use business-page-family reference-fit rule");
    }
  }

  const report = {
    schema_version: "0.1.0",
    status: failures.length ? "fail" : "pass",
    script: "validate-pattern-resolver",
    checked: {
      pattern_id: resolution.pattern_id || "unknown",
      registry_item: resolution.registry_item || "unknown",
      template_id: resolution.template_id || "unknown",
      page_subtype: resolution.page_subtype || "unknown",
      delivery_contract: resolution.delivery_contract?.id || "none",
      sections: sectionIds.size,
      missing_sections: missingSections.length,
      forbidden_sections: presentForbiddenSections.length,
      required_primitives: resolution.required_primitives?.length || 0,
      fallbacks: resolution.fallbacks?.length || 0,
      required_rules: resolution.required_rules?.length || 0
    },
    failures
  };
  fs.writeFileSync(reportPath, JSON.stringify(report, null, 2) + "\n");
  if (failures.length) {
    console.error(`Pattern resolver validation failed: ${failures.join("; ")}`);
    process.exit(1);
  }
  console.log(`Pattern resolver OK: ${resolution.pattern_id} (${resolution.template_id})`);
}

module.exports = { validatePatternResolver };

if (require.main === module) {
  validatePatternResolver();
}
