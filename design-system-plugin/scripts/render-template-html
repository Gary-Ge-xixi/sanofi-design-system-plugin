function renderOneCommercialQueryPanel(resolution, template, outputPath, context = {}) {
  const tokenSource = resolution.source_provenance.token_source;
  const fallbackReason = (resolution.source_provenance.fallback_reasons || []).find((item) => item.module === "table")?.reason || "No official Table/DataTable/DataGrid primitive is registered locally.";
  const profileId = resolution.page_profile?.id || "admin-data-entry-table";
  const densityId = resolution.page_profile?.density_id || context.densityRule?.density_id || "admin-compact";
  const referenceFitId = resolution.page_profile?.reference_fit_id || "admin-data-entry-table-reference-fit";
  const navAttrs = attrs(resolution, "navigation-header", "admin-query-panel-header");
  const sidebarAttrs = attrs(resolution, "sidebar", "admin-query-panel-sidebar");
  const containerAttrs = attrs(resolution, "container", "admin-query-panel", {
    "data-layout-rule": "layout-grid-container",
    "data-source-doc-id": "foundations-layout--docs components-container--docs",
    "data-container-part": "root",
    "data-container-mode": "fixed",
    "data-container-width-token": "--elements-container-width-2xl"
  });
  const gridAttrs = attrs(resolution, "grid", "admin-query-panel", {
    "data-layout-rule": "layout-grid-container",
    "data-source-doc-id": "foundations-layout--docs components-grid--docs",
    "data-grid-part": "root",
    "data-grid-columns": "12",
    "data-grid-gap-token": "--elements-grid-gutter-lg"
  });
  const buttonAttrs = attrs(resolution, "button", "admin-query-panel-action");
  const textInputAttrs = attrs(resolution, "text-input", "editable-table-cell");
  const paginationAttrs = attrs(resolution, "pagination", "table-pagination");
  const filters = (template.filters || []).map((label, index) => renderFilterSelect(resolution, label, index)).join("");
  const actions = (template.actions || []).map((action) => {
    const className = action.variant === "primary" ? "btn btn-primary" : action.variant === "secondary" ? "btn btn-secondary" : "btn btn-link";
    return `<button class="${className}" type="button" ${buttonAttrs} data-variant="${escapeHtml(action.variant)}">${escapeHtml(action.label)}${action.variant === "primary" ? " →" : ""}</button>`;
  }).join("");
  const headers = (template.table.columns || []).map((column) => `<th scope="col">${escapeHtml(column)}</th>`).join("");
  const rows = (template.table.rows || []).map((row) => `<tr><td>${escapeHtml(row.month)}</td><td>${escapeHtml(row.code)}</td><td>${escapeHtml(row.name)}</td><td>${escapeHtml(row.spec)}</td><td>${escapeHtml(row.group)}</td><td><input ${textInputAttrs} type="text" value="${escapeHtml(row.quantity)}" aria-label="数量"></td></tr>`).join("");

  const html = `<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>${escapeHtml(template.title)}</title>
    <link rel="stylesheet" href="../../design-system/tokens/tokens.css">
    <style>${stylesheet(context.densityRule)}</style>
  </head>
  <body data-design-system="sanofi-elements" data-registry-item="${escapeHtml(resolution.registry_item)}" data-template="${escapeHtml(template.template)}" data-template-id="${escapeHtml(resolution.template_id)}" data-page-subtype="${escapeHtml(resolution.page_subtype)}" data-page-profile="${escapeHtml(profileId)}" data-pattern="${escapeHtml(resolution.pattern_id)}" data-token-source="${escapeHtml(tokenSource)}" data-output-state-official-runtime="absent" data-output-state-local-atomic-runtime="present" data-output-state-explicit-fallback="present" data-typography-rule="typography-font-stack" data-page-layout-typography="business-layout-typography" data-app-shell-scroll="content-only" data-scroll-rule="business-app-shell-scroll" data-density="${escapeHtml(densityId)}" data-density-rule="admin-density" data-reference-fit="admin-data-entry-table" data-reference-fit-rule="${escapeHtml(referenceFitId)}" data-elevation-rule="elevation-usage" data-source-doc-id="foundations-typography--docs foundations-layout--docs components-pageheader--docs components-container--docs components-grid--docs foundations-elevation--docs">
    <div class="template-shell" data-app-shell="business-admin" data-app-shell-scroll="content-only">
      <header class="template-topbar" data-template-part="topbar" data-app-shell-part="topbar" data-scroll-fixed="true" data-elevation-role="header" data-elevation-token="--elements-core-elevation-02" ${navAttrs}>
        <div class="brand-lockup"><span class="brand-word"><span class="brand-dot">.</span>${escapeHtml(template.app.brand)}</span><span class="brand-divider" aria-hidden="true"></span><span class="app-name">${escapeHtml(template.app.name)}</span></div>
        <div class="topbar-actions"><span class="avatar">${escapeHtml(template.app.avatar)}</span></div>
      </header>
      <aside class="template-sidebar" data-template-part="sidebar" data-sidebar-part="root" ${attrs(resolution, "sidebar", "admin-query-panel-sidebar", {
        "data-story-id": "components-sidebar--expanded",
        "data-sidebar-state": "expanded"
      })}>
        <div class="sidebar-header" data-sidebar-part="header"></div>
        <nav data-sidebar-part="content" aria-label="主导航"><ul class="nav-list" data-list-kind="sidebar-navigation" data-list-level="0">${(template.sidebar || []).map((item) => renderSidebarItem(resolution, item)).join("")}</ul></nav>
        <div class="sidebar-footer" data-sidebar-part="footer"><button class="sidebar-collapse" type="button" aria-label="收起侧边栏" ${attrs(resolution, "button", "sidebar-collapse", {
          "data-variant": "tertiary-neutral",
          "data-story-id": "components-buttonicon--tertiary-neutral"
        })}>☰</button></div>
      </aside>
      <main class="main" data-template-part="main" data-app-shell-part="content" data-scroll-region="content">
        <section class="container" ${containerAttrs}>
          <div class="grid" ${gridAttrs}>
            <article class="content-panel" data-pattern="admin-query-panel" data-template-part="content" data-container-part="contentContainer" data-grid-part="item">
              <nav class="breadcrumb" data-section="breadcrumb" aria-label="面包屑"><strong>${escapeHtml(template.breadcrumb[0])}</strong><span>›</span><span>${escapeHtml(template.breadcrumb[1])}</span></nav>
              <section class="page-heading" data-primitive="page-header" data-source-component="page-header" data-story-id="components-pageheader--default" data-source-doc-id="components-pageheader--docs foundations-typography--docs foundations-layout--docs" data-pageheader-part="root" data-container-type="fixed">
                <div data-pageheader-part="content">
                  <h1 class="page-title-text" data-pageheader-part="title">${escapeHtml(template.heading.title)}</h1>
                  <p class="page-description" data-pageheader-part="description">${escapeHtml(template.heading.meta)}</p>
                </div>
                <div class="page-header-actions" data-pageheader-part="actions" aria-hidden="true"></div>
              </section>
              <section class="query-toolbar" data-template-part="query-toolbar" data-section="query-toolbar" data-module-contract="select-filter">${filters}<button class="btn btn-secondary" type="button" ${buttonAttrs} data-variant="secondary">筛选</button><button class="btn btn-secondary" type="button" ${buttonAttrs} data-variant="secondary">重置</button><button class="btn btn-link" type="button" ${buttonAttrs} data-variant="link">更多⌄</button></section>
              <div class="button-row" data-section="primary-actions">${actions}</div>
              <section class="table-wrap" data-template-part="editable-table" data-section="editable-data-table-fallback" data-module-contract="data-table-fallback" data-list-kind="editable-table-list" data-table-list-role="fallback" data-fallback-module="table" data-fallback-reason="${escapeHtml(fallbackReason)}"><table aria-label="${escapeHtml(template.heading.title)}"><thead><tr>${headers}</tr></thead><tbody><tr class="summary-row"><td>${escapeHtml(template.table.summary_label)}</td><td colspan="4"></td><td class="summary-value">${escapeHtml(template.table.summary_value)}</td></tr>${rows}</tbody></table></section>
              <nav class="pagination-row" data-section="pagination" ${paginationAttrs} aria-label="分页"><span>${escapeHtml(template.pagination.total)}，每页</span><span class="page-size">${escapeHtml(template.pagination.page_size)}</span><span>条</span><button class="btn btn-link" type="button" ${buttonAttrs} data-variant="link" aria-label="上一页">‹</button><span class="page-current" aria-current="page">${escapeHtml(template.pagination.current_page)}</span><button class="btn btn-link" type="button" ${buttonAttrs} data-variant="link" aria-label="下一页">›</button></nav>
            </article>
          </div>
        </section>
      </main>
    </div>
    <div class="save-bar" data-template-part="save-bar" data-section="save-bar" data-elevation-role="sticky-action" data-elevation-token="--elements-core-elevation-03" data-source-doc-id="foundations-elevation--docs"><button class="btn ${template.save_bar.disabled ? "btn-disabled" : "btn-primary"}" type="button" ${buttonAttrs} data-variant="primary" data-state="${template.save_bar.disabled ? "disabled" : "enabled"}"${template.save_bar.disabled ? " disabled" : ""}>${escapeHtml(template.save_bar.button)}</button><span>${escapeHtml(template.save_bar.status)}</span></div>
    ${runtimeScript()}
  </body>
</html>`;
  fs.mkdirSync(path.dirname(outputPath), { recursive: true });
  fs.writeFileSync(outputPath, html);
}

function renderTemplateHtml(args = []) {
  const resolutionPath = args[0] ? path.resolve(process.cwd(), args[0]) : path.join(pluginRoot, "design-system", "contracts", "resolvers", "latest-resolution.json");
  const resolution = readJson(resolutionPath);
  if (resolution.template_id !== "onecommercial-admin-query-panel") {
    if (resolution.pattern_id === "admin-dashboard") {
      const { renderDashboardTemplateHtml } = require("./render-dashboard-template-html");
      renderDashboardTemplateHtml(args);
      return;
    }
    const { renderResolvedHtml } = require("./render-admin-template-html");
    renderResolvedHtml(args);
    return;
  }
  const templatePath = resolution.source_provenance?.template_path ? absFromWorkspace(resolution.source_provenance.template_path) : path.join(pluginRoot, "design-system", "templates", "onecommercial-admin-query-panel.template.json");
  const template = readJson(templatePath);
  const densityRulePath = resolution.source_provenance?.density_rule_path ? absFromWorkspace(resolution.source_provenance.density_rule_path) : path.join(pluginRoot, "design-system", "rules", "admin-density.json");
  const tableContractPath = (resolution.source_provenance?.page_module_contracts || []).find((item) => item.endsWith("data-table-fallback.contract.json"));
  const dataTableFallbackContractPath = tableContractPath ? absFromWorkspace(tableContractPath) : path.join(pluginRoot, "design-system", "contracts", "page-modules", "data-table-fallback.contract.json");
  const densityRule = readOptionalJson(densityRulePath, {});
  const dataTableFallbackContract = readOptionalJson(dataTableFallbackContractPath, {});
  const outputPath = args[1] ? path.resolve(process.cwd(), args[1]) : path.join(pluginRoot, "outputs", "html", "admin-query-panel.resolved.html");
  const reportDir = path.join(pluginRoot, "outputs", "reports");
  const reportPath = path.join(reportDir, "html-renderer.report.json");
  renderOneCommercialQueryPanel(resolution, template, outputPath, {
    densityRule,
    dataTableFallbackContract
  });
  fs.mkdirSync(reportDir, { recursive: true });
  fs.writeFileSync(reportPath, JSON.stringify({
    schema_version: "0.1.0",
    status: "pass",
    script: "render-template-html",
    target: rel(outputPath),
    consumed: {
      registry_item: resolution.registry_item,
      pattern_id: resolution.pattern_id,
      template_id: resolution.template_id,
      template_path: resolution.source_provenance.template_path,
      design_md_path: resolution.source_provenance.design_md_path,
      page_profile: resolution.page_profile,
      page_module_contracts: resolution.source_provenance.page_module_contracts,
      density_rule_path: resolution.source_provenance.density_rule_path,
      reference_fit_rule_path: resolution.source_provenance.reference_fit_rule_path,
      data_table_fallback_contract_id: dataTableFallbackContract.id || "unknown",
      page_subtype: resolution.page_subtype,
      required_rules: resolution.required_rules
    },
    counts: {
      sections: resolution.sections?.length || 0,
      primitive_refs: resolution.primitive_refs?.length || 0,
      table_rows: template.table?.rows?.length || 0
    }
  }, null, 2) + "\n");
  console.log(`HTML rendered: ${rel(outputPath)} (${resolution.template_id})`);
}

module.exports = { renderTemplateHtml };

if (require.main === module) {
  renderTemplateHtml(process.argv.slice(2));
}
