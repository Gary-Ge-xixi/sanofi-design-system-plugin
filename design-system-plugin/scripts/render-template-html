#!/usr/bin/env node
const fs = require("fs");
const path = require("path");
const { runtimeScript } = require("../component-runtime/src/local-components.cjs");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function readOptionalJson(filePath, fallback) {
  if (!filePath || !fs.existsSync(filePath)) return fallback;
  return readJson(filePath);
}

function rel(filePath) {
  return path.relative(pluginRoot, filePath).replaceAll(path.sep, "/");
}

function absFromWorkspace(relativePath) {
  return path.join(workspaceRoot, relativePath);
}

function escapeHtml(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function primitive(resolution, id) {
  return (resolution.primitive_refs || []).find((item) => item.primitive_id === id) || {
    docs_id: "unknown",
    story_id: "unknown"
  };
}

function attrs(resolution, primitiveId, patternId, extra = {}) {
  const ref = primitive(resolution, primitiveId);
  const values = {
    "data-primitive": primitiveId,
    "data-source-component": primitiveId,
    "data-story-id": ref.story_id,
    "data-source-doc-id": ref.docs_id,
    "data-pattern": patternId,
    "data-token-source": resolution.source_provenance.token_source,
    ...extra
  };
  return Object.entries(values)
    .map(([key, value]) => `${key}="${escapeHtml(value)}"`)
    .join(" ");
}

function runtimeAttrs(resolution, primitiveId, patternId, instance, extra = {}) {
  return attrs(resolution, primitiveId, patternId, {
    "data-component-runtime": "sanofi-local-atomic-components",
    "data-render-source": "local-atomic-component-package",
    "data-component-instance": instance,
    "data-component-id": primitiveId,
    ...extra
  });
}

const iconPaths = {
  home: '<rect x="4" y="4" width="6" height="6" rx="1"></rect><rect x="14" y="4" width="6" height="6" rx="1"></rect><rect x="4" y="14" width="6" height="6" rx="1"></rect><rect x="14" y="14" width="6" height="6" rx="1"></rect>',
  table: '<rect x="3" y="5" width="18" height="16" rx="1.5"></rect><path d="M3 10h18"></path><path d="M8 5v16"></path>',
  approval: '<rect x="5" y="4" width="14" height="18" rx="1.5"></rect><path d="M8 9h8"></path><path d="M8 13h8"></path><path d="M8 17h5"></path>',
  balance: '<path d="M4 19V5"></path><path d="M4 19h17"></path><rect x="7" y="10" width="3" height="6" rx=".5"></rect><rect x="12" y="7" width="3" height="9" rx=".5"></rect><rect x="17" y="12" width="3" height="4" rx=".5"></rect>',
  system: '<rect x="4" y="5" width="16" height="14" rx="1.5"></rect><path d="M8 9h8"></path><path d="M8 13h8"></path>',
  chevronDown: '<path d="m7 10 5 5 5-5"></path>'
};

function renderIcon(resolution, name, className = "nav-icon") {
  const iconAttr = attrs(resolution, "icon", "admin-query-panel", {
    "data-icon-name": name,
    "aria-hidden": "true"
  });
  return `<span class="${className}" ${iconAttr}><svg viewBox="0 0 24 24" focusable="false">${iconPaths[name] || iconPaths.home}</svg></span>`;
}

function menuAttrs(resolution, current = false, expanded = null, extra = {}) {
  if (current) extra["aria-current"] = "page";
  if (expanded !== null) extra["aria-expanded"] = expanded ? "true" : "false";
  return attrs(resolution, "menu", "admin-query-panel", extra);
}

function renderSidebarItem(resolution, item) {
  const hasChildren = Array.isArray(item.items) && item.items.length;
  const parentClass = item.active ? "nav-item is-active" : "nav-item";
  const expanded = hasChildren ? item.expanded !== false : null;
  const icon = item.icon ? renderIcon(resolution, item.icon) : "";
  const chevron = hasChildren ? renderIcon(resolution, "chevronDown", "nav-chevron") : "";
  const children = hasChildren
    ? `<ul class="nav-children" data-sidebar-part="section" data-list-kind="sidebar-sub-list" data-list-level="1">${item.items.map((child) => {
        const childClass = child.active ? "nav-child is-active" : "nav-child";
        return `<li data-list-item-kind="child"><a class="${childClass}" href="#" data-sidebar-part="item" data-menu-role="item" data-menu-level="1" ${menuAttrs(resolution, Boolean(child.active), null, {
          "data-source-component": "menu-menu-item",
          "data-story-id": "components-menu-menuitem--default"
        })}>${escapeHtml(child.label)}</a></li>`;
      }).join("")}</ul>`
    : "";
  return `<li data-sidebar-part="section" data-list-item-kind="${hasChildren ? "parent-with-children" : "parent"}">
    <a class="${parentClass}" href="#" data-sidebar-part="item" data-menu-role="${hasChildren ? "submenu-trigger" : "item"}" data-menu-level="0" ${menuAttrs(resolution, Boolean(item.active), expanded, {
      "data-story-id": hasChildren ? "components-menu--with-sub-menus" : "components-menu-menuitem--default",
      "data-source-component": hasChildren ? "menu" : "menu-menu-item"
    })}>
      ${icon}<span>${escapeHtml(item.label)}</span>${chevron}
    </a>
    ${children}
  </li>`;
}

function renderFilterSelect(resolution, label, index) {
  const id = `query-filter-${index + 1}`;
  const rootAttrs = runtimeAttrs(resolution, "select", "query-toolbar", `select.${id}`, {
    "data-module-contract": "select-filter",
    "data-select-part": "field",
    "data-select-size": "medium",
    "data-select-shell": "normal",
    "data-select-edge-safe": "true",
    "data-select-native": "false",
    "data-native": "false"
  });
  const selectAttrs = attrs(resolution, "select", "query-toolbar", {
    "data-select-part": "native",
    "data-select-native": "true",
    "data-select-size": "medium",
    "data-select-label-position": "top"
  });
  const triggerAttrs = attrs(resolution, "select", "query-toolbar", {
    "data-select-part": "trigger",
    "data-select-native": "false",
    "data-select-size": "medium",
    "data-select-label-position": "top"
  });
  return `<label class="filter-field" ${rootAttrs}>
    <span class="select-label sr-only" id="${id}-label">${escapeHtml(label)}</span>
    <span class="select-shell" data-module-contract="select-filter" data-select-part="root">
      <select class="select-native" id="${id}-native" ${selectAttrs} aria-labelledby="${id}-label" tabindex="-1">
        <option>${escapeHtml(label)}</option>
      </select>
      <button class="select-trigger" type="button" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="${id}-label ${id}-value" aria-controls="${id}-listbox" data-select-trigger ${triggerAttrs}>
        <span class="select-value" id="${id}-value" data-select-value>${escapeHtml(label)}</span>
        ${renderIcon(resolution, "chevronDown", "select-chevron")}
      </button>
      <span class="select-options" id="${id}-listbox" role="listbox" hidden data-select-listbox>
        <span role="option" data-value="${escapeHtml(label)}" aria-selected="true">${escapeHtml(label)}</span>
      </span>
    </span>
  </label>`;
}

