#!/usr/bin/env node
const fs = require("fs");
const https = require("https");
const path = require("path");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");
const reportDir = path.join(pluginRoot, "outputs", "reports");
const researchDir = path.join(reportDir, "web-research", "oneorbit-sources");
const registryPath = path.join(pluginRoot, "design-system", "registry", "registry.json");
const outputJsonPath = path.join(reportDir, "oneorbit-component-source-resolution.json");
const outputMdPath = path.join(reportDir, "oneorbit-component-source-resolution.md");

const remoteSources = {
  storybook_index: "https://elements.prod.accelerator.sanofi/index.json",
  storybook_stories: "https://elements.prod.accelerator.sanofi/stories.json"
};

const localDownloads = {
  storybook_index: path.join(researchDir, "storybook-index.json"),
  storybook_stories: path.join(researchDir, "storybook-stories.json")
};

const queryPlan = [
  {
    id: "table",
    terms: ["table", "data grid", "datagrid"],
    local_queries: ["table", "data table", "data grid"],
    decision: "semantic-html-fallback",
    reason: "No official Table/DataGrid component entry is exposed in the Storybook index and no local Table/DataGrid primitive is registered.",
    local_contracts: [
      "design-system-plugin/design-system/contracts/page-modules/business-table.contract.json",
      "design-system-plugin/design-system/contracts/page-modules/data-table-fallback.contract.json"
    ]
  },
  {
    id: "date-range",
    terms: ["date picker", "datepicker"],
    required_story_ids: ["components-datepicker--range", "components-calendar--range-selection"],
    local_queries: ["date range", "date picker range"],
    decision: "docs-registry-backed-primitive",
    reason: "DatePicker range stories are present in Storybook and local registry, but the local runtime adapter is not registered in the first-round component runtime.",
    local_contracts: [
      "design-system-plugin/design-system/knowledge/docs/components-datepicker--docs.md",
      "design-system-plugin/design-system/primitives/components/date-picker/primitive.json"
    ]
  },
  {
    id: "message-list",
    terms: ["message list", "notification", "card list", "content block list"],
    required_story_ids: ["components-card--list-density-view", "components-card--list-date-view", "components-contentblock--selectable-list"],
    local_queries: ["message list", "card list", "content block list"],
    decision: "compound-card-list-pattern",
    reason: "No MessageList component entry is exposed; Card list and ContentBlock list stories are available, so message items should compose Card, Button, and Icon rather than claim MessageList runtime.",
    local_contracts: [
      "design-system-plugin/design-system/knowledge/docs/components-card--docs.md",
      "design-system-plugin/design-system/primitives/components/card/primitive.json",
      "design-system-plugin/design-system/contracts/components/content-block.contract.json"
    ]
  }
];

function fetchText(url, redirects = 0) {
  return new Promise((resolve, reject) => {
    https.get(url, {
      headers: {
        Accept: "application/json",
        "User-Agent": "curl/8.7.1"
      }
    }, (response) => {
      if ([301, 302, 303, 307, 308].includes(response.statusCode) && response.headers.location) {
        if (redirects >= 5) {
          reject(new Error(`GET ${url} exceeded redirect limit`));
          response.resume();
          return;
        }
        const nextUrl = new URL(response.headers.location, url).toString();
        response.resume();
        fetchText(nextUrl, redirects + 1).then(resolve, reject);
        return;
      }
      if (response.statusCode < 200 || response.statusCode >= 300) {
        reject(new Error(`GET ${url} returned ${response.statusCode}`));
        response.resume();
        return;
      }
      let data = "";
      response.setEncoding("utf8");
      response.on("data", (chunk) => {
        data += chunk;
      });
      response.on("end", () => resolve(data));
    }).on("error", reject);
  });
}

function readJson(filePath, fallback = null) {
  if (!fs.existsSync(filePath)) return fallback;
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function normalize(value) {
  return String(value || "").toLowerCase().replace(/-/g, " ");
}

function tokenize(value) {
  return normalize(value).split(/[^a-z0-9\u4e00-\u9fff]+/u).filter(Boolean);
}

function entryText(entry) {
  return normalize([entry.id, entry.title, entry.name, entry.type, entry.importPath].join(" "));
}

function searchEntries(entries, query) {
  const terms = tokenize(query);
  return entries
    .filter((entry) => {
      const text = entryText(entry);
      return terms.every((term) => text.includes(term));
    })
    .slice(0, 20)
    .map((entry) => ({
      id: entry.id,
      title: entry.title,
      name: entry.name,
      type: entry.type,
      importPath: entry.importPath
    }));
}

function scoreRegistryItem(itemRef, item, query) {
  const terms = tokenize(query);
  const text = normalize([
    item.name,
    item.title,
    item.description,
    item.type,
    item.component_id,
    item.pattern_id,
    ...(item.ai?.prompt_keywords || [])
  ].join(" "));
  return terms.reduce((score, term) => score + (text.includes(term) ? 1 : 0), 0);
}

function searchRegistry(query) {
  const registry = readJson(registryPath, { items: [] });
  return (registry.items || [])
    .map((itemRef) => {
      const absoluteItemPath = path.join(workspaceRoot, itemRef.path);
      const item = readJson(absoluteItemPath, {});
      return {
        score: scoreRegistryItem(itemRef, item, query),
        name: item.name,
        title: item.title,
        type: item.type,
        path: itemRef.path,
        registryDependencies: item.registryDependencies || []
      };
    })
    .filter((item) => item.score > 0)
    .sort((a, b) => b.score - a.score || a.name.localeCompare(b.name))
    .slice(0, 10);
}

function markdownTable(rows) {
  return [
    "| Target | Decision | Remote Hits | Local Hits | Reason | Evidence |",
    "| --- | --- | --- | --- | --- | --- |",
    ...rows.map((row) => {
      return `| ${row.target} | ${row.decision} | ${row.remote_hit_count} | ${row.local_hit_count} | ${row.reason.replace(/\|/g, "/")} | ${row.evidence.join("<br>").replace(/\|/g, "/")} |`;
    })
  ].join("\n");
}

async function main() {
  fs.mkdirSync(researchDir, { recursive: true });
  fs.mkdirSync(reportDir, { recursive: true });

  for (const [key, url] of Object.entries(remoteSources)) {
    const content = await fetchText(url);
    JSON.parse(content);
    fs.writeFileSync(localDownloads[key], content);
  }

  const storybookIndex = readJson(localDownloads.storybook_index, { entries: {} });
  const storybookStories = readJson(localDownloads.storybook_stories, { stories: {} });
  const remoteEntries = [
    ...Object.values(storybookIndex.entries || {}),
    ...Object.values(storybookStories.stories || {})
  ];

  const decisions = queryPlan.map((item) => {
    const remoteHitsByQuery = item.terms.map((query) => ({
      query,
      hits: searchEntries(remoteEntries, query)
    }));
    const requiredHits = (item.required_story_ids || [])
      .map((storyId) => remoteEntries.find((entry) => entry.id === storyId))
      .filter(Boolean)
      .map((entry) => ({
        id: entry.id,
        title: entry.title,
        name: entry.name,
        type: entry.type,
        importPath: entry.importPath
      }));
    const localHitsByQuery = item.local_queries.map((query) => ({
      query,
      hits: searchRegistry(query)
    }));
    const remoteHitIds = new Set([
      ...remoteHitsByQuery.flatMap((query) => query.hits.map((hit) => hit.id)),
      ...requiredHits.map((hit) => hit.id)
    ]);
    const localHitNames = new Set(localHitsByQuery.flatMap((query) => query.hits.map((hit) => hit.name)));
    const evidence = [
      ...requiredHits.slice(0, 4).map((hit) => `${hit.id} (${hit.importPath})`),
      ...localHitsByQuery.flatMap((query) => query.hits.slice(0, 2).map((hit) => `${hit.name} (${hit.path})`)),
      ...item.local_contracts
    ];
    return {
      target: item.id,
      decision: item.decision,
      reason: item.reason,
      remote_queries: remoteHitsByQuery,
      required_story_hits: requiredHits,
      local_registry_queries: localHitsByQuery,
      local_contracts: item.local_contracts,
      remote_hit_count: remoteHitIds.size,
      local_hit_count: localHitNames.size,
      evidence: [...new Set(evidence)].slice(0, 12)
    };
  });

  const report = {
    schema_version: "0.1.0",
    generated_at: new Date().toISOString(),
    script: "resolve-oneorbit-component-sources",
    remote_sources: {
      storybook_index: remoteSources.storybook_index,
      storybook_stories: remoteSources.storybook_stories
    },
    local_downloads: {
      storybook_index: path.relative(pluginRoot, localDownloads.storybook_index),
      storybook_stories: path.relative(pluginRoot, localDownloads.storybook_stories)
    },
    decisions
  };
  fs.writeFileSync(outputJsonPath, JSON.stringify(report, null, 2) + "\n");

  const md = [
    "# OneOrbit Component Source Resolution",
    "",
    "该报告把 Table、DateRange、MessageList 先走线上 Storybook index 下载与本地 registry 检索，再给出 runtime / primitive / fallback 决策。",
    "",
    `- Storybook index: ${remoteSources.storybook_index}`,
    `- Storybook stories: ${remoteSources.storybook_stories}`,
    `- Local index: ${path.relative(pluginRoot, localDownloads.storybook_index)}`,
    `- Local stories: ${path.relative(pluginRoot, localDownloads.storybook_stories)}`,
    "",
    markdownTable(decisions),
    ""
  ].join("\n");
  fs.writeFileSync(outputMdPath, md);

  console.log(`OneOrbit source resolution OK: ${path.relative(pluginRoot, outputJsonPath)}`);
}

main().catch((error) => {
  console.error(`OneOrbit source resolution failed: ${error.message}`);
  process.exit(1);
});
