const atomicStoryItems = (atomicIndex.stories || []).map((storyRef) => {
  const story = readJson(storyRef.path);
  const name = storyRef.registry_item || toRegistryName(`${story.component_id}-${story.args?.values?.variant || story.story_name}-atomic-story`);
  const componentAtomicPath = localPath("design-system", "atomic", "components", story.component_id, "component.atomic.json");
  return {
    schema_version: "0.1.0",
    name,
    title: `${story.component_name} ${story.story_name} atomic story`,
    type: "registry:story",
    renderer_target: "html",
    description: `Callable local Storybook story atom for ${story.story_id}.`,
    atomic_story_id: story.story_id,
    component_id: story.component_id,
    docs_id: story.source_provenance?.docs_id,
    registryDependencies: [
      "sanofi-elements-tokens",
      "sanofi-design-prototype-generator",
      toRegistryName(story.component_id)
    ],
    files: compact([
      asFile(storyRef.path, "atomic-story"),
      exists(componentAtomicPath) ? asFile(componentAtomicPath, "atomic-component-contract") : null,
      asFile(story.source.local_bundle_path, "raw-story-bundle"),
      asFile(story.source.local_iframe_path, "raw-story-iframe"),
      asFile(story.template.local_path, "atomic-template"),
      asFile(story.component_contract.local_path, "component-contract"),
      asFile(story.primitive.local_path, "primitive-contract"),
      asFile(localPath("design-system", "knowledge", "docs", `${story.source_provenance.docs_id}.md`), "source-doc")
    ]),
    source_provenance: {
      docs_id: story.source_provenance.docs_id,
      story_id: story.story_id,
      atomic_story: storyRef.path,
      atomic_component_contract: exists(componentAtomicPath) ? componentAtomicPath : "unsupported",
      story_url: story.source.story_url,
      iframe_url: story.source.iframe_url,
      bundle_url: story.source.bundle_url,
      raw_bundle: story.source.local_bundle_path,
      component_contract: story.component_contract.local_path,
      primitive_contract: story.primitive.local_path,
      token_source: story.source_provenance.token_source
    },
    ai: {
      prompt_keywords: [
        story.component_id,
        story.component_name,
        story.story_name,
        story.story_id,
        story.args?.values?.variant,
        "atomic",
        "story",
        "原子",
        "组件"
      ].filter(Boolean),
      when_to_use: `Use when a prompt asks for the exact ${story.component_name} ${story.story_name} Storybook state.`,
      unsupported_behavior: "Do not infer other variants from this story item. Use another story atom or materialize it first."
    }
  };
});

const packageItems = componentPackages.map(({ path: packagePath, package: pkg }) => {
  const componentId = pkg.component_id;
  const packageName = toRegistryName(`${componentId}-complete-package`);
  const isButton = componentId === "button";
  return {
    schema_version: "0.1.0",
    name: packageName,
    title: `${pkg.component_name} complete standard package`,
    type: "registry:package",
    renderer_target: "html",
    description: `Complete local ${pkg.component_name} package covering Docs plus all Storybook story atoms.`,
    component_id: componentId,
    registryDependencies: [
      "sanofi-elements-tokens",
      "sanofi-design-prototype-generator",
      toRegistryName(componentId)
    ],
    files: compact([
      asFile(packagePath, "atomic-component-package"),
      asFile(pkg.expected_tabs, "expected-tabs"),
      asFile(pkg.docs_contract?.local_path, "docs-contract"),
      asFile(pkg.component_atomic_contract, "atomic-component-contract"),
      asFile(pkg.render_outputs?.complete_html, "example-html"),
      asFile(pkg.component_contract, "component-contract"),
      pkg.primitive_contract !== "unsupported" ? asFile(pkg.primitive_contract, "primitive-contract") : null,
      pkg.docs_contract?.docs_id ? asFile(localPath("design-system", "knowledge", "docs", `${pkg.docs_contract.docs_id}.md`), "source-doc") : null
    ]),
    coverage: pkg.coverage,
    story_atoms: (pkg.story_atoms || []).map((story) => ({
      story_id: story.story_id,
      story_name: story.story_name,
      semantic_type: story.semantic_type,
      registry_item: toRegistryName(`${componentId}-${story.variant !== "not_applicable" && story.semantic_type === "variant" ? story.variant : story.story_name}-atomic-story`)
    })),
    source_provenance: pkg.source_provenance,
    ai: {
      prompt_keywords: [
        componentId,
        pkg.component_name,
        `${componentId} complete`,
        `${pkg.component_name} complete package`,
        `${componentId} docs`,
        ...(isButton ? [
          "button link",
          "primary neutral button",
          "secondary neutral button",
          "destructive button",
          "overview inverse",
          "按钮",
          "完整按钮包"
        ] : [])
      ],
      when_to_use: `Use first for any ${pkg.component_name} generation request, then resolve the exact story atom by intent.`,
      unsupported_behavior: `Do not infer ${pkg.component_name} behavior outside the package stories, docs contract, and primitive contract.`
    }
  };
});

const blockItems = [
  adminQueryItem,
  adminItem,
  reportDashboardItem,
  informationAggregationItem,
  customerDetailDateQueryItem
].filter(Boolean);

const items = [tokenItem, brandAssetItem, workflowItem, runtimeItem, ...blockItems, ...primitiveItems, ...packageItems, ...atomicStoryItems].filter(Boolean).map((item) => {
  const cleanItem = { ...item };
  delete cleanItem._story_ids;
  writeJson(itemPath(item.name), cleanItem);
  return {
    name: item.name,
    title: item.title,
    type: item.type,
    renderer_target: item.renderer_target,
    path: itemPath(item.name),
    registryDependencies: item.registryDependencies,
    prompt_keywords: item.ai?.prompt_keywords || []
  };
});

const registry = {
  schema_version: "0.1.0",
  name: "sanofi-elements-local-registry",
  description: "Private local registry for Sanofi Elements AI HTML prototype generation.",
  generated_at: generatedAt,
  renderer_target: "html",
  source_mode: "local-first",
  source_priority: [
    "interface: local DESIGN.md AI-readable design-system contract",
    ...(sourceIndex.source_priority || [])
  ],
  counts: {
    items: items.length,
    component_items: primitiveItems.length,
    story_items: atomicStoryItems.length,
    package_items: packageItems.length,
    block_items: blockItems.length,
    style_items: 1,
    lib_items: 2,
    docs: sourceIndex.counts?.storybook_docs || 0,
    stories: sourceIndex.counts?.storybook_stories || 0,
    component_contracts: componentContractIndex.counts?.component_contracts || 0
  },
  items,
  commands: {
    search: localPath("scripts", "search-local-registry"),
    validate: localPath("scripts", "validate-local-registry"),
    validate_design_md: localPath("scripts", "validate-design-md"),
    validate_admin_page_profile: localPath("scripts", "validate-admin-page-profile"),
    validate_component_runtime: localPath("scripts", "validate-component-runtime"),
    validate_reference_fit: localPath("scripts", "validate-reference-fit"),
    materialize_story_atom: localPath("scripts", "materialize-story-atom"),
    build_generic_primitives: localPath("scripts", "build-generic-primitives"),
    build_atomic_library: localPath("scripts", "build-atomic-library"),
    validate_atomic_library: localPath("scripts", "validate-atomic-library"),
    build_component_coverage_matrix: localPath("scripts", "build-component-coverage-matrix"),
    build_component_package_factory: localPath("scripts", "build-component-package-factory"),
    validate_component_package_dom: localPath("scripts", "validate-component-package-dom"),
    validate_component_package_html_batch: localPath("scripts", "validate-component-package-html-batch"),
    render_atomic_html: localPath("scripts", "render-atomic-html"),
    render_button_package: localPath("scripts", "render-button-package"),
    render_component_package: localPath("scripts", "render-component-package"),
    resolve_pattern: localPath("scripts", "resolve-pattern"),
    render_dashboard_html: localPath("scripts", "render-dashboard-template-html"),
    render_html: localPath("scripts", "render-resolved-html")
  },
  remote_refresh_policy: {
    normal_generation: "Use this local registry; do not scrape remote docs.",
    upstream_update: "Refresh local MD/contracts/tokens from new source URLs, then run build-local-registry and validators.",
    primary_remote_base: "https://elements.prod.accelerator.sanofi/"
  }
};

writeJson(localPath("design-system", "registry", "registry.json"), registry);
writeJson(localPath("outputs", "reports", "local-registry-build.report.json"), {
  schema_version: "0.1.0",
  status: "pass",
  script: "build-local-registry",
  generated_at: generatedAt,
  output: localPath("design-system", "registry", "registry.json"),
  counts: registry.counts
});

console.log(
  `Local registry built: ${items.length} items (${primitiveItems.length} components, ${atomicStoryItems.length} stories, ${packageItems.length} packages, ${blockItems.length} blocks, 1 style, 2 libs)`
