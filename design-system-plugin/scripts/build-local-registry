#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");
const registryDir = path.join(pluginRoot, "design-system", "registry");
const itemsDir = path.join(registryDir, "items");
const reportDir = path.join(pluginRoot, "outputs", "reports");

function readJson(relativePath) {
  return JSON.parse(fs.readFileSync(path.join(workspaceRoot, relativePath), "utf8"));
}

function exists(relativePath) {
  return fs.existsSync(path.join(workspaceRoot, relativePath));
}

function readOptionalJson(relativePath, fallback) {
  if (!exists(relativePath)) return fallback;
  return readJson(relativePath);
}

function writeJson(relativePath, data) {
  const absolutePath = path.join(workspaceRoot, relativePath);
  fs.mkdirSync(path.dirname(absolutePath), { recursive: true });
  fs.writeFileSync(absolutePath, JSON.stringify(data, null, 2) + "\n");
}

function localPath(...parts) {
  return path.join("design-system-plugin", ...parts).replaceAll(path.sep, "/");
}

function toRegistryName(value) {
  return `sanofi-${String(value)
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "")}`;
}

function itemPath(name) {
  return localPath("design-system", "registry", "items", `${name}.json`);
}

function asFile(pathValue, role, target = pathValue) {
  return {
    path: pathValue,
    role,
    target
  };
}

function compact(value) {
  return Array.isArray(value) ? value.filter(Boolean) : [];
}

function ruleId(rule) {
  return typeof rule === "string" ? rule : rule?.id;
}

function patternDetail(entry) {
  if (!entry?.path) return entry || null;
  const detailPath = localPath("design-system", "patterns", entry.path);
  if (!exists(detailPath)) return entry;
  return {
    ...entry,
    ...readJson(detailPath)
  };
}

function walk(dir, predicate, results = []) {
  if (!fs.existsSync(dir)) return results;
  for (const entry of fs.readdirSync(dir)) {
    const absolutePath = path.join(dir, entry);
    if (fs.statSync(absolutePath).isDirectory()) {
      walk(absolutePath, predicate, results);
    } else if (predicate(absolutePath)) {
      results.push(absolutePath);
    }
  }
  return results.sort();
}

function rel(absolutePath) {
  return path.relative(workspaceRoot, absolutePath).replaceAll(path.sep, "/");
}

fs.mkdirSync(itemsDir, { recursive: true });
fs.mkdirSync(reportDir, { recursive: true });

const generatedAt = new Date().toISOString();
const sourceIndex = readJson("design-system-plugin/design-system/knowledge/source-index.json");
const primitiveIndex = readJson("design-system-plugin/design-system/primitives/primitive-index.json");
const componentContractIndex = readJson(
  "design-system-plugin/design-system/contracts/components/component-contract-index.json"
);
const semanticTokenMap = readJson("design-system-plugin/design-system/contracts/semantic-token-map.json");
const patternIndex = readJson("design-system-plugin/design-system/patterns/pattern-index.json");
const adminResolution = readJson(
  "design-system-plugin/design-system/contracts/resolvers/admin-dashboard.resolution.json"
);
const atomicIndex = readOptionalJson(
  "design-system-plugin/design-system/atomic/atomic-component-index.json",
  { stories: [], counts: { stories: 0, components: 0 } }
);
const componentPackages = walk(
  path.join(pluginRoot, "design-system", "atomic", "components"),
  (filePath) => filePath.endsWith(".package.json")
)
  .map((filePath) => ({ path: rel(filePath), package: readJson(rel(filePath)) }))
  .filter((record) => record.package.coverage?.story_coverage_status === "complete")
  .sort((a, b) => a.package.component_id.localeCompare(b.package.component_id));

const contractsByPrimitive = new Map();
for (const contract of componentContractIndex.contracts || []) {
  contractsByPrimitive.set(contract.id, contract);
  for (const primitiveId of contract.primitive_ids || []) {
    contractsByPrimitive.set(primitiveId, contract);
  }
}

const primitiveItems = (primitiveIndex.primitives || []).map((primitive) => {
  const contract = contractsByPrimitive.get(primitive.id);
  const name = toRegistryName(primitive.id);
  const docsId = contract?.docs_id || null;
  const storyIds = contract?.story_count ? undefined : [];

  return {
    schema_version: "0.1.0",
    name,
    title: `${primitive.component} primitive`,
    type: "registry:component",
    renderer_target: "html",
    description: `Local Sanofi Elements primitive contract for ${primitive.component}.`,
    status: primitive.status,
    component_id: primitive.id,
    docs_id: docsId,
    registryDependencies: ["sanofi-elements-tokens", "sanofi-design-prototype-generator"],
    files: compact([
      asFile(localPath("design-system", "primitives", primitive.path), "primitive-contract"),
      asFile(localPath("design-system", "primitives", primitive.demo_registry), "demo-registry"),
      contract ? asFile(contract.local_contract_path, "component-contract") : null,
      docsId ? asFile(localPath("design-system", "knowledge", "docs", `${docsId}.md`), "source-doc") : null
    ]),
    source_provenance: {
      docs_id: docsId || "unknown",
      component_contract: contract?.local_contract_path || "unsupported",
      token_source: semanticTokenMap.source?.primary_docs_entry || "foundations-colors--docs",
      story_count: contract?.story_count ?? "not_extracted",
      primitive_registry: localPath("design-system", "primitives", "primitive-index.json")
    },
    ai: {
      prompt_keywords: [
        primitive.id,
        primitive.component,
        primitive.component.replace(/([a-z])([A-Z])/g, "$1 $2")
      ],
      when_to_use: `Use for HTML prototypes that need the official ${primitive.component} primitive.`,
      unsupported_behavior: "Do not invent props or states beyond the component contract."
    },
    _story_ids: storyIds
  };
});

