#!/usr/bin/env node
const fs = require("fs");
const os = require("os");
const path = require("path");
const cp = require("child_process");
const { pathToFileURL } = require("url");
const { resolveChromePath, chromeInstallHint } = require("./lib/chrome-path.cjs");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");
const htmlDir = path.join(pluginRoot, "outputs", "html");
const reportDir = path.join(pluginRoot, "outputs", "reports");
const port = 9237;

const pages = [
  {
    id: "business-query-form",
    file: path.join(htmlDir, "business-query-form.resolved.html")
  },
  {
    id: "business-entity-detail",
    file: path.join(htmlDir, "business-entity-detail.resolved.html")
  },
  {
    id: "information-aggregation",
    file: path.join(htmlDir, "information-aggregation.resolved.html")
  }
];

function rel(filePath) {
  return path.relative(workspaceRoot, filePath).replaceAll(path.sep, "/");
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function waitForChrome() {
  const endpoint = `http://127.0.0.1:${port}/json/version`;
  for (let i = 0; i < 40; i += 1) {
    try {
      const response = await fetch(endpoint);
      if (response.ok) return;
    } catch {
      await sleep(125);
    }
  }
  throw new Error("Chrome DevTools endpoint did not start");
}

function createCdp(wsUrl) {
  const ws = new WebSocket(wsUrl);
  let id = 0;
  const pending = new Map();
  const opened = new Promise((resolve, reject) => {
    ws.addEventListener("open", resolve, { once: true });
    ws.addEventListener("error", reject, { once: true });
  });
  ws.addEventListener("message", (event) => {
    const message = JSON.parse(event.data);
    if (!message.id || !pending.has(message.id)) return;
    const { resolve, reject } = pending.get(message.id);
    pending.delete(message.id);
    if (message.error) reject(new Error(message.error.message));
    else resolve(message.result);
  });
  return {
    async send(method, params = {}) {
      await opened;
      id += 1;
      ws.send(JSON.stringify({ id, method, params }));
      return new Promise((resolve, reject) => {
        pending.set(id, { resolve, reject });
      });
    },
    close() {
      ws.close();
    }
  };
}

async function createPage(filePath) {
  const url = pathToFileURL(filePath).href;
  const response = await fetch(`http://127.0.0.1:${port}/json/new?${encodeURIComponent(url)}`, {
    method: "PUT"
  });
  if (!response.ok) throw new Error(`Failed to create Chrome tab for ${filePath}`);
  return response.json();
}

async function measurePage(page) {
  const target = await createPage(page.file);
  const cdp = createCdp(target.webSocketDebuggerUrl);
  await cdp.send("Page.enable");
  await cdp.send("Runtime.enable");
  await sleep(700);
  const expression = `(() => {
    const root = document.documentElement;
    const body = document.body;
    const scrollWidth = Math.max(root.scrollWidth, body.scrollWidth);
    const clientWidth = root.clientWidth;
    return {
      innerWidth: window.innerWidth,
      innerHeight: window.innerHeight,
      scrollWidth,
      clientWidth,
      hasHorizontalOverflow: scrollWidth > clientWidth,
      pageProfile: body.dataset.pageProfile,
      pageFamily: body.dataset.pageFamily,
      sections: Array.from(document.querySelectorAll("[data-section]")).map((node) => node.getAttribute("data-section")),
      fieldCount: document.querySelectorAll("[data-field-id]").length,
      businessFormModules: document.querySelectorAll('[data-business-module="business-form"]').length,
      businessChartModules: document.querySelectorAll('[data-business-module="business-chart"]').length,
      businessTableModules: document.querySelectorAll('[data-business-module="business-table"]').length
    };
  })()`;
  const result = await cdp.send("Runtime.evaluate", {
    expression,
    returnByValue: true
  });
  cdp.close();
  return {
    id: page.id,
    path: rel(page.file),
    ...result.result.value
  };
}

async function main() {
  fs.mkdirSync(reportDir, { recursive: true });
  const chromePath = resolveChromePath();
  if (!chromePath) throw new Error(chromeInstallHint());

  const userDataDir = fs.mkdtempSync(path.join(os.tmpdir(), "sanofi-business-pages-"));
  const chrome = cp.spawn(chromePath, [
    "--headless=new",
    "--disable-gpu",
    "--no-first-run",
    "--no-default-browser-check",
    "--disable-extensions",
    "--hide-scrollbars",
    "--window-size=1440,900",
    `--remote-debugging-port=${port}`,
    `--user-data-dir=${userDataDir}`,
    "about:blank"
  ], {
    stdio: "ignore"
  });

  try {
    await waitForChrome();
    const measurements = [];
    for (const page of pages) {
      measurements.push(await measurePage(page));
    }
    const failures = measurements
      .filter((item) => item.hasHorizontalOverflow)
      .map((item) => `${item.id}: scrollWidth ${item.scrollWidth} exceeds clientWidth ${item.clientWidth}`);
    const report = {
      schema_version: "0.1.0",
      status: failures.length ? "fail" : "pass",
      script: "measure-business-page-examples",
      generated_at: new Date().toISOString(),
      viewport: {
        width: 1440,
        height: 900
      },
      measurements,
      failures
    };
    fs.writeFileSync(path.join(reportDir, "business-page-examples-geometry.report.json"), JSON.stringify(report, null, 2) + "\n");
    fs.writeFileSync(
      path.join(reportDir, "business-page-examples-geometry.report.md"),
      `# Business Page Examples Geometry\n\nStatus: ${report.status}\n\n| Page | Client width | Scroll width | Fields | Sections |\n|---|---:|---:|---:|---:|\n${measurements.map((item) => `| ${item.id} | ${item.clientWidth} | ${item.scrollWidth} | ${item.fieldCount} | ${item.sections.length} |`).join("\n")}\n\n## Failures\n\n${failures.length ? failures.map((failure) => `- ${failure}`).join("\n") : "- None"}\n`
    );
    if (failures.length) {
      console.error(`Business page geometry failed: ${failures.join("; ")}`);
      process.exitCode = 1;
    } else {
      console.log(`Business page geometry OK: ${measurements.length} pages at 1440x900`);
    }
  } finally {
    chrome.kill("SIGTERM");
  }
}

main().catch((error) => {
  console.error(error.message);
  process.exit(1);
});
