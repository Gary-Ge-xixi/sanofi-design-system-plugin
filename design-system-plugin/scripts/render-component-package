#!/usr/bin/env node
const fs = require("fs");
const path = require("path");
const { execFileSync } = require("child_process");

const pluginRoot = path.resolve(__dirname, "..");
const workspaceRoot = path.resolve(pluginRoot, "..");

function readJson(relativePath) {
  return JSON.parse(fs.readFileSync(path.join(workspaceRoot, relativePath), "utf8"));
}

function exists(relativePath) {
  return fs.existsSync(path.join(workspaceRoot, relativePath));
}

function writeText(relativePath, content) {
  const absolutePath = path.join(workspaceRoot, relativePath);
  fs.mkdirSync(path.dirname(absolutePath), { recursive: true });
  fs.writeFileSync(absolutePath, content);
}

function writeJson(relativePath, data) {
  const absolutePath = path.join(workspaceRoot, relativePath);
  fs.mkdirSync(path.dirname(absolutePath), { recursive: true });
  fs.writeFileSync(absolutePath, JSON.stringify(data, null, 2) + "\n");
}

function escapeHtml(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function attr(value) {
  return escapeHtml(value);
}

function attrs(attributes) {
  return Object.entries(attributes || {})
    .filter(([, value]) => value !== false && value !== undefined && value !== null)
    .map(([key, value]) => (value === true ? key : `${key}="${attr(value)}"`))
    .join(" ");
}

function className(value) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9_-]+/g, "-")
    .replace(/(^-|-$)/g, "");
}

function renderSample(story, pkg) {
  const common = {
    "data-primitive": pkg.component_id,
    "data-pattern": "atomic-component-sample",
    "data-story-id": story.story_id,
    "data-source-doc-id": pkg.docs_contract.docs_id,
    "data-token-source": pkg.source_provenance.token_source,
    "data-variant": story.variant,
    "data-state": story.semantic_type
  };
  const label = escapeHtml(story.story_name || pkg.component_name);
  const primitiveId = pkg.component_id;
  if (primitiveId === "search-input") {
    return `<label class="sample-shell">Search<span><input ${attrs({ ...common, class: "sample-control", type: "search", placeholder: "Search" })} /></span></label>`;
  }
  if (primitiveId === "select") {
    return `<label class="sample-shell">Select<select ${attrs({ ...common, class: "sample-control" })}><option>${label}</option></select></label>`;
  }
  if (primitiveId === "tabs") {
    return `<div class="sample-shell" ${attrs({ ...common, role: "tablist" })}><button class="sample-control" type="button" role="tab" aria-selected="true">${label}</button><button class="sample-control" type="button" role="tab" aria-selected="false">Related</button></div>`;
  }
  if (primitiveId === "progress-bar") {
    return `<div class="sample-shell"><div ${attrs({ ...common, class: "sample-control", role: "progressbar", "aria-valuenow": "64", "aria-valuemin": "0", "aria-valuemax": "100" })}>64%</div></div>`;
  }
  if (primitiveId === "tag") {
    return `<span ${attrs({ ...common, class: "sample-control", "data-variant": story.variant || "neutral" })}>${label}</span>`;
  }
  if (primitiveId === "card") {
    return `<article ${attrs({ ...common, class: "sample-shell" })}><strong>${escapeHtml(pkg.component_name)}</strong><span>${label}</span></article>`;
  }
  if (primitiveId === "checkbox" || primitiveId === "checkbox-checkbox-group" || primitiveId === "checkbox-group") {
    const inputId = `package-${className(story.story_id)}`;
    return `<fieldset class="sample-shell" ${attrs(common)}><legend>${escapeHtml(pkg.component_name)}</legend><input id="${attr(inputId)}" type="checkbox" /><label for="${attr(inputId)}">${label}</label></fieldset>`;
  }
  if (primitiveId === "radio" || primitiveId === "radio-radio-group") {
    const inputId = `package-${className(story.story_id)}`;
    return `<fieldset class="sample-shell" ${attrs(common)}><legend>${escapeHtml(pkg.component_name)}</legend><input id="${attr(inputId)}" type="radio" checked /><label for="${attr(inputId)}">${label}</label></fieldset>`;
  }
  if (primitiveId === "sidebar") {
    return `<aside ${attrs({ ...common, "data-sidebar-part": "root" })}><div data-sidebar-part="header">${escapeHtml(pkg.component_name)}</div><nav data-sidebar-part="content"><section data-sidebar-part="section"><a data-sidebar-part="item" aria-current="page" href="#">${label}</a></section></nav><div data-sidebar-part="footer">Footer</div></aside>`;
  }
  if (primitiveId === "menu") {
    return `<nav ${attrs(common)}><a class="sample-control" aria-current="page" href="#">${label}</a></nav>`;
  }
  if (primitiveId === "button-icon") {
    return `<button ${attrs({ ...common, class: "sample-control", type: "button" })}>${label}</button>`;
  }
  return `<article ${attrs({ ...common, class: "sample-shell" })}><strong>${escapeHtml(pkg.component_name)}</strong><span>${label}</span><code>${escapeHtml(story.story_id)}</code></article>`;
}

function baseHtml({ title, mainPattern, pkg, body }) {
  return `<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>${escapeHtml(title)}</title>
    <link rel="stylesheet" href="../../design-system/tokens/tokens.css" />
    <style>
      :root { color-scheme: light; font-family: Arial, sans-serif; }
      body {
        margin: 0;
        min-block-size: 100vh;
        background: var(--elements-color-semantic-background-neutral);
        color: var(--elements-color-semantic-text-default_inverse);
      }
      main {
        display: grid;
        gap: var(--elements-spacing-xl);
        padding: var(--elements-spacing-2xl);
      }
      .demo-panel, .story-card {
        display: grid;
        gap: var(--elements-spacing-md);
        border: 0.0625rem solid var(--elements-color-semantic-border-subtle);
        border-radius: var(--elements-radius-md);
        background: var(--elements-color-semantic-background-neutral);
        padding: var(--elements-spacing-xl);
      }
      .story-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
        gap: var(--elements-spacing-lg);
      }
      .sample-shell {
        display: grid;
        gap: var(--elements-spacing-sm);
        border: 0.0625rem dashed var(--elements-color-semantic-border-subtle);
        border-radius: var(--elements-radius-sm);
        background: var(--elements-color-semantic-background-neutral);
        padding: var(--elements-spacing-lg);
      }
      .sample-control {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-block-size: 2.5rem;
        max-inline-size: 28rem;
        border: 0.0625rem solid var(--elements-color-semantic-border-default);
        border-radius: var(--elements-radius-sm);
        background: var(--elements-color-semantic-background-neutral);
        color: var(--elements-color-semantic-text-default_inverse);
        padding-inline: var(--elements-spacing-lg);
      }
      code { color: var(--elements-color-semantic-text-accent-default); }
    </style>
  </head>
  <body data-design-system="sanofi-elements">
    <main data-pattern="${attr(mainPattern)}" data-source-doc-id="${attr(pkg.docs_contract.docs_id)}" data-token-source="${attr(pkg.source_provenance.token_source)}">
${body}
    </main>
  </body>
</html>
`;
}

function renderPackage(componentId) {
  if (componentId === "button") {
    execFileSync("node", ["design-system-plugin/scripts/render-button-package"], {
      cwd: workspaceRoot,
      stdio: "inherit"
    });
    return {
      component_id: componentId,
      status: "delegated-to-button-renderer"
    };
  }

  const packagePath = `design-system-plugin/design-system/atomic/components/${componentId}/${componentId}.package.json`;
  if (!exists(packagePath)) throw new Error(`missing package: ${packagePath}`);
  const pkg = readJson(packagePath);
  if (pkg.coverage?.story_coverage_status !== "complete") {
    throw new Error(`${componentId} package is not complete`);
  }

  const storyCards = (pkg.story_atoms || []).map((story) => `
        <article class="story-card" data-pattern="atomic-story-card" data-story-id="${attr(story.story_id)}" data-source-doc-id="${attr(pkg.docs_contract.docs_id)}">
          <h2>${escapeHtml(story.story_name)}</h2>
          ${renderSample(story, pkg)}
          <p><code>${escapeHtml(story.story_id)}</code></p>
        </article>`).join("\n");

  const completeHtml = baseHtml({
    title: `${pkg.component_name} complete package`,
    mainPattern: "atomic-component-package",
    pkg,
    body: `
      <section class="demo-panel" data-pattern="atomic-component-summary" data-source-doc-id="${attr(pkg.docs_contract.docs_id)}">
        <h1>${escapeHtml(pkg.component_name)} Complete Package</h1>
        <p>Docs: ${escapeHtml(pkg.docs_contract.docs_id)}. Stories: ${pkg.coverage.materialized_stories}/${pkg.coverage.expected_stories}.</p>
      </section>
      <section class="demo-panel" data-pattern="atomic-story-grid" data-source-doc-id="${attr(pkg.docs_contract.docs_id)}">
        <h2>Story Atoms</h2>
        <div class="story-grid">
${storyCards}
        </div>
      </section>
      <section class="demo-panel" data-pattern="atomic-source-provenance" data-source-doc-id="${attr(pkg.docs_contract.docs_id)}">
        <h2>Source Provenance</h2>
        <p><code>${escapeHtml(pkg.component_contract)}</code></p>
        <p><code>${escapeHtml(pkg.primitive_contract)}</code></p>
      </section>`
  });
  writeText(pkg.render_outputs.complete_html, completeHtml);

  for (const story of pkg.story_atoms || []) {
    if (!story.render_output_path || story.render_output_path === "missing") continue;
    const storyHtml = baseHtml({
      title: `${pkg.component_name} ${story.story_name}`,
      mainPattern: "atomic-story-reference",
      pkg,
      body: `
      <section class="demo-panel" data-pattern="atomic-story-card" data-story-id="${attr(story.story_id)}" data-source-doc-id="${attr(pkg.docs_contract.docs_id)}">
        <h1>${escapeHtml(pkg.component_name)} / ${escapeHtml(story.story_name)}</h1>
        ${renderSample(story, pkg)}
        <p><code>${escapeHtml(story.story_id)}</code></p>
      </section>`
    });
    writeText(story.render_output_path, storyHtml);
  }

  return {
    component_id: componentId,
    status: "rendered",
    output: pkg.render_outputs.complete_html,
    story_outputs: (pkg.story_atoms || []).length
  };
}

const arg = process.argv[2];
if (!arg) {
  console.error("Usage: render-component-package <component-id|--all>");
  process.exit(1);
}

const components = arg === "--all"
  ? fs.readdirSync(path.join(pluginRoot, "design-system", "atomic", "components"))
      .filter((entry) => exists(`design-system-plugin/design-system/atomic/components/${entry}/${entry}.package.json`))
      .sort()
  : [arg];

const results = [];
for (const componentId of components) {
  results.push(renderPackage(componentId));
}

writeJson("design-system-plugin/outputs/reports/component-package-renderer.report.json", {
  schema_version: "0.1.0",
  status: "pass",
  script: "render-component-package",
  results
});

console.log(`Component package renderer OK: ${results.length} package(s)`);
