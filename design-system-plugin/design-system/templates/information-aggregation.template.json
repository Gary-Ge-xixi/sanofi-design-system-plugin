      "data-page-profile=\"information-aggregation\"",
      "data-page-family=\"information-aggregation\"",
      "data-reference-fit=\"business-page-family\""
    ],
    "module_order": [
      "query filters",
      "dashboard summary",
      "chart context",
      "record list",
      "pagination"
    ],
    "fallback_policy": "Table remains explicit fallback until an official Table/DataGrid primitive is registered. BarChart uses business-chart when the data contract is present."
  },
  "source_provenance": {
