    "table-usage",
    "form-usage",
    "business-page-family-reference-fit"
  ],
  "required_module_contracts": [
    "business-form",
    "business-chart",
    "business-table"
  ],
  "sections": [
    {
      "id": "breadcrumb",
      "role": "navigation",
      "required": true
    },
    {
      "id": "aggregation-header",
      "role": "page-header",
      "required": true
    },
    {
      "id": "filter-toolbar",
      "role": "business-form",
