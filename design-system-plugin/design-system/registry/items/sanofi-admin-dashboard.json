      "path": "design-system-plugin/design-system/patterns/admin-dashboard/admin-dashboard.pattern.json",
      "role": "pattern",
      "target": "design-system-plugin/design-system/patterns/admin-dashboard/admin-dashboard.pattern.json"
    },
    {
