{
  "schema_version": "0.1.0",
  "name": "sanofi-admin-dashboard",
  "title": "Sanofi admin dashboard block",
  "type": "registry:block",
  "renderer_target": "html",
  "description": "A local HTML block pattern for admin dashboard pages using Sanofi Elements primitives, contract-backed BarChart modules, and explicit fallbacks for unsupported table or chart modules.",
  "pattern_id": "admin-dashboard",
  "registryDependencies": [
    "sanofi-elements-tokens",
    "sanofi-design-prototype-generator",
    "sanofi-elements-component-runtime",
    "sanofi-brand-assets",
    "sanofi-container",
    "sanofi-grid",
    "sanofi-navigation-header",
    "sanofi-sidebar",
    "sanofi-menu",
    "sanofi-icon",
    "sanofi-search-input",
    "sanofi-select",
    "sanofi-button",
    "sanofi-card",
    "sanofi-tag",
    "sanofi-tabs",
    "sanofi-progress-bar"
  ],
  "files": [
