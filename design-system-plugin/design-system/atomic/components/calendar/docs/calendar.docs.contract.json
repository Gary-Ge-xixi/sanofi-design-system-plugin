    "snippets": [
      "import { Calendar } from \"@sanofi-accelerator/elements\";\n\nconst Component = () => (\n  <Calendar\n    onSelectedDateChange={(event) => console.log(event.target.value)}\n  />\n);\n\n// to disable specific days\nconst Component = () => (\n  <Calendar\n    onSelectedDateChange={(event) => console.log(event.target.value)}\n    disabledDates={[\n            \"2025-02-01\",\n            \"2025-02-06\",\n            \"2025-02-12\",\n            \"2025-02-15\",\n            \"2025-02-18\",\n            \"2025-02-20\",\n            \"2025-02-23\",\n            \"2025-02-26\",\n          ]}\n  />\n);\n\n// to disable weekends\nconst Component = () => (\n  <Calendar\n    onSelectedDateChange={(event) => console.log(event.target.value)}\n    disabledDates={(date) => [0, 6].includes(date.getDay())}\n  />\n);"
    ]
