    "required_source_doc_ids": [
      "foundations-layout--docs",
      "components-container--docs",
      "components-grid--docs"
    ],
    "required_story_ids": [
      "components-container--fixed",
      "components-grid--desktop"
    ]
  },
  "generation_policy": [
    "Admin pages must resolve layout before visual components.",
    "Use Container to constrain main content width and Grid.Root/Grid.Item semantics for responsive sections.",
    "Do not place dashboard modules directly under body or main without a container and grid wrapper.",
    "Use Elements spacing, grid gutter, breakpoint, and container tokens instead of raw pixel values in generated HTML.",
    "A Container marker is not sufficient: generated HTML must preserve the root/contentContainer structure from the Container component.",
    "A Grid marker is not sufficient: generated HTML must preserve Grid.Root and Grid.Item equivalent structure for direct layout children."
