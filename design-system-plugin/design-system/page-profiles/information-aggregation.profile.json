{
  "schema_version": "0.1.0",
  "id": "information-aggregation",
  "status": "standard-ready",
  "renderer_target": "html",
  "page_family": "information-aggregation",
  "intent": {
    "page_type": "backend-admin",
    "primary_task": "aggregate-and-investigate",
    "language": "zh-CN"
  },
  "required_rules": [
    "business-page-standards",
    "form-usage",
    "chart-usage",
    "table-usage",
    "density-standards",
    "business-layout-typography",
    "business-app-shell-scroll",
    "business-page-family-reference-fit"
  ],
  "required_module_contracts": [
    "business-form",
    "business-chart",
    "business-table"
  ],
  "section_contract": {
    "required_sections": [
      "breadcrumb",
      "aggregation-header",
      "filter-toolbar",
      "dashboard-summary",
      "chart-region",
      "record-list",
      "pagination"
    ],
    "forbidden_sections": [
      "marketing-hero",
      "standalone-dashboard-without-list",
      "list-without-query-context"
    ],
    "required_attrs": [
      "data-page-profile=\"information-aggregation\"",
      "data-page-family=\"information-aggregation\"",
      "data-business-task=\"aggregate-and-investigate\""
    ]
  },
  "module_requirements": {
    "query": {
      "module_contract_id": "business-form",
      "minimum_filter_count": 4,
      "required_flows": [
        "query",
        "export"
      ]
    },
    "dashboard": {
      "module_contract_id": "business-chart",
      "minimum_kpi_count": 4,
      "required_chart_kinds": [
        "bar"
      ],
      "requires_accessible_table": true
    },
    "list": {
      "module_contract_id": "business-table",
      "minimum_column_count": 6,
      "minimum_body_rows": 5,
      "requires_pagination": true
    }
  },
  "state_requirements": [
    "loading",
    "empty",
    "error",
    "readonly",
    "permission-denied"
  ],
  "generation_policy": [
    "Information aggregation pages must show query filters, dashboard summary, and list results in one content scroll region.",
    "Dashboard metrics must reflect the current query scope and must not appear as unrelated marketing cards.",
    "The record list must preserve table fallback markers until an official Table/DataGrid primitive is registered.",
    "The chart area must expose exact values through an accessible data table or adjacent record list."
  ]
}
